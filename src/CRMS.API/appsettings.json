{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=crmsdb;User=YOUR_USER;Pwd=YOUR_PASSWORD;"
  },
  "JwtSettings": {
    "Issuer": "CRMS.API",
    "Audience": "CRMS.Clients",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "FileStorage": {
    "Provider": "Local",
    "LocalPath": "./storage"
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "MaxTokens": 4096,
    "Temperature": 0.3,
    "TimeoutSeconds": 60
  },
  "AIAdvisory": {
    "UseLLMNarrative": false,
    "LLMTimeoutSeconds": 30,
    "FallbackToTemplateOnFailure": true,
    "LogLLMInteractions": false
  },
  "FineractDirect": {
    "BaseUrl": "https://localhost:8443/core_banking/api",
    "Username": "",
    "Password": "",
    "TenantId": "default",
    "TimeoutSeconds": 30,
    "UseMock": true
  },
  "AllowedHosts": "*"
}
