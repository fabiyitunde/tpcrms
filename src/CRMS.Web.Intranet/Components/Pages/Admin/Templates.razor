@page "/admin/templates"
@inject NavigationManager Navigation
@inject ApplicationService AppService
@inject AuthService AuthService

<PageTitle>Notification Templates - CRMS</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Notification Templates</h1>
        <p class="page-subtitle">Manage email, SMS, and WhatsApp notification templates</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenCreateModal">
        <span class="material-symbols-outlined" style="font-size: 18px;">add</span>
        Add Template
    </button>
</div>

<div class="card mb-6">
    <div class="card-body" style="padding: var(--space-4);">
        <div style="display: flex; gap: var(--space-4); flex-wrap: wrap; align-items: flex-end;">
            <div style="flex: 1; min-width: 200px;">
                <label class="form-label">Search</label>
                <input type="text" class="form-control" placeholder="Template name or code..." @bind="searchTerm" @bind:event="oninput" />
            </div>
            <div style="width: 150px;">
                <label class="form-label">Channel</label>
                <select class="form-control" @bind="selectedChannel">
                    <option value="">All Channels</option>
                    <option value="Email">Email</option>
                    <option value="SMS">SMS</option>
                    <option value="WhatsApp">WhatsApp</option>
                    <option value="InApp">In-App</option>
                </select>
            </div>
            <div style="width: 150px;">
                <label class="form-label">Status</label>
                <select class="form-control" @bind="selectedStatus">
                    <option value="">All</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                </select>
            </div>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="card">
        <div class="card-body" style="text-align: center; padding: var(--space-8);">
            <div class="spinner"></div>
            <p style="margin-top: var(--space-4); color: var(--gray-500);">Loading templates...</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body" style="padding: 0;">
            <table class="table">
                <thead>
                    <tr>
                        <th>Template Name</th>
                        <th>Channel</th>
                        <th>Type</th>
                        <th>Version</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!FilteredTemplates.Any())
                    {
                        <tr>
                            <td colspan="6" style="text-align: center; padding: var(--space-8); color: var(--gray-500);">
                                No templates found matching your criteria.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var template in FilteredTemplates)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight: 500;">@template.Name</div>
                                    <div style="font-size: var(--text-xs); color: var(--gray-500);">@template.Code</div>
                                </td>
                                <td>
                                    <span class="badge @GetChannelBadgeClass(template.Channel)">
                                        <span class="material-symbols-outlined" style="font-size: 14px;">@GetChannelIcon(template.Channel)</span>
                                        @template.Channel
                                    </span>
                                </td>
                                <td style="font-size: var(--text-sm);">@FormatType(template.Type)</td>
                                <td>
                                    <span class="badge badge-gray">v@template.Version</span>
                                </td>
                                <td>
                                    <span class="badge @(template.IsActive ? "badge-success" : "badge-gray")">
                                        @(template.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <div style="display: flex; gap: var(--space-2);">
                                        <button class="btn btn-ghost btn-sm" @onclick="() => EditTemplate(template)" title="Edit">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                                        </button>
                                        <button class="btn btn-ghost btn-sm" @onclick="() => PreviewTemplate(template)" title="Preview">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">visibility</span>
                                        </button>
                                        <button class="btn btn-ghost btn-sm" @onclick="() => ToggleTemplate(template)" title="@(template.IsActive ? "Deactivate" : "Activate")">
                                            <span class="material-symbols-outlined" style="font-size: 18px; color: @(template.IsActive ? "var(--danger-600)" : "var(--success-600)");">
                                                @(template.IsActive ? "toggle_off" : "toggle_on")
                                            </span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="card mt-6">
    <div class="card-header">
        <h3 class="card-title">Available Variables</h3>
    </div>
    <div class="card-body">
        <div class="variables-grid">
            @foreach (var variable in availableVariables)
            {
                <div class="variable-item">
                    <code>@("{{" + variable.Name + "}}")</code>
                    <span>@variable.Description</span>
                </div>
            }
        </div>
    </div>
</div>

@if (showTemplateModal)
{
    <div class="modal-backdrop show" @onclick="CloseModal">
        <div class="modal" style="max-width: 700px;" @onclick:stopPropagation>
            <div class="modal-header">
                <h3 class="modal-title">@(isEditing ? "Edit Template" : "Add New Template")</h3>
                <button class="modal-close" @onclick="CloseModal">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="grid grid-cols-2 gap-4">
                    <div class="form-group">
                        <label class="form-label">Template Name *</label>
                        <input type="text" class="form-control" @bind="editingTemplate.Name" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Template Code *</label>
                        <input type="text" class="form-control" @bind="editingTemplate.Code" disabled="@isEditing" />
                        @if (!isEditing)
                        {
                            <small style="color: var(--gray-500);">Unique identifier, cannot be changed later</small>
                        }
                    </div>
                    <div class="form-group">
                        <label class="form-label">Channel *</label>
                        <select class="form-control" @bind="editingTemplate.Channel" disabled="@isEditing">
                            <option value="">Select Channel</option>
                            <option value="Email">Email</option>
                            <option value="SMS">SMS</option>
                            <option value="WhatsApp">WhatsApp</option>
                            <option value="InApp">In-App</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Type *</label>
                        <select class="form-control" @bind="editingTemplate.Type" disabled="@isEditing">
                            <option value="">Select Type</option>
                            <option value="ApplicationSubmitted">Application Submitted</option>
                            <option value="ApplicationApproved">Application Approved</option>
                            <option value="ApplicationRejected">Application Rejected</option>
                            <option value="ApplicationReturned">Application Returned</option>
                            <option value="WorkflowAssigned">Workflow Assigned</option>
                            <option value="WorkflowSLAWarning">SLA Warning</option>
                            <option value="WorkflowSLABreached">SLA Breached</option>
                            <option value="CommitteeVoteRequired">Committee Vote Required</option>
                            <option value="CommitteeDecisionMade">Committee Decision Made</option>
                            <option value="CreditCheckCompleted">Credit Check Completed</option>
                            <option value="DocumentRequired">Document Required</option>
                            <option value="SystemAlert">System Alert</option>
                            <option value="Custom">Custom</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <input type="text" class="form-control" @bind="editingTemplate.Description" placeholder="Brief description of when this template is used" />
                </div>
                @if (editingTemplate.Channel == "Email")
                {
                    <div class="form-group">
                        <label class="form-label">Subject *</label>
                        <input type="text" class="form-control" @bind="editingTemplate.Subject" placeholder="Email subject line with {{variables}}" />
                    </div>
                }
                <div class="form-group">
                    <label class="form-label">Body Template *</label>
                    <textarea class="form-control" rows="8" @bind="editingTemplate.BodyTemplate" 
                              placeholder="Use {{variable}} syntax for dynamic content..."></textarea>
                </div>
                @if (editingTemplate.Channel == "Email")
                {
                    <div class="form-group">
                        <label class="form-label">HTML Body (Optional)</label>
                        <textarea class="form-control" rows="6" @bind="editingTemplate.BodyHtmlTemplate" 
                                  placeholder="HTML version of the email body (optional)"></textarea>
                    </div>
                }
            </div>
            <div class="modal-footer">
                @if (!string.IsNullOrEmpty(saveError))
                {
                    <div style="color: var(--danger-600); font-size: var(--text-sm); margin-right: auto;">@saveError</div>
                }
                <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveTemplate" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="spinner"></span>
                    }
                    @(isEditing ? "Update" : "Create") Template
                </button>
            </div>
        </div>
    </div>
}

@if (showPreviewModal)
{
    <div class="modal-backdrop show" @onclick="ClosePreviewModal">
        <div class="modal" style="max-width: 600px;" @onclick:stopPropagation>
            <div class="modal-header">
                <h3 class="modal-title">Template Preview: @previewTemplate?.Name</h3>
                <button class="modal-close" @onclick="ClosePreviewModal">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="modal-body">
                @if (previewTemplate != null)
                {
                    <div class="form-group">
                        <label class="form-label">Channel</label>
                        <span class="badge @GetChannelBadgeClass(previewTemplate.Channel)">@previewTemplate.Channel</span>
                    </div>
                    @if (!string.IsNullOrEmpty(previewTemplate.Subject))
                    {
                        <div class="form-group">
                            <label class="form-label">Subject</label>
                            <div style="background: var(--gray-50); padding: var(--space-3); border-radius: var(--radius-md); font-family: monospace;">
                                @previewTemplate.Subject
                            </div>
                        </div>
                    }
                    <div class="form-group">
                        <label class="form-label">Body</label>
                        <div style="background: var(--gray-50); padding: var(--space-3); border-radius: var(--radius-md); white-space: pre-wrap; font-family: monospace; max-height: 300px; overflow-y: auto;">
                            @previewTemplate.BodyTemplate
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="ClosePreviewModal">Close</button>
            </div>
        </div>
    </div>
}

<style>
    .variables-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: var(--space-3);
    }
    
    .variable-item {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        padding: var(--space-2) var(--space-3);
        background: var(--gray-50);
        border-radius: var(--radius-md);
    }
    
    .variable-item code {
        background: var(--primary-100);
        color: var(--primary-700);
        padding: var(--space-1) var(--space-2);
        border-radius: var(--radius-sm);
        font-size: var(--text-xs);
        white-space: nowrap;
    }
    
    .variable-item span {
        font-size: var(--text-sm);
        color: var(--gray-600);
    }
</style>

@code {
    private List<NotificationTemplateInfo> templates = [];
    private string searchTerm = string.Empty;
    private string selectedChannel = string.Empty;
    private string selectedStatus = string.Empty;
    private bool showTemplateModal;
    private bool showPreviewModal;
    private bool isEditing;
    private bool isSaving;
    private bool isLoading = true;
    private string? saveError;
    private NotificationTemplateInfo editingTemplate = new();
    private NotificationTemplateInfo? previewTemplate;

    private List<VariableInfo> availableVariables =
    [
        new() { Name = "ApplicationNumber", Description = "Loan application number" },
        new() { Name = "CustomerName", Description = "Customer/Company name" },
        new() { Name = "Amount", Description = "Requested loan amount" },
        new() { Name = "Status", Description = "Current application status" },
        new() { Name = "AssignedTo", Description = "Assigned user name" },
        new() { Name = "DueDate", Description = "SLA due date" },
        new() { Name = "CommitteeName", Description = "Committee name" },
        new() { Name = "VoteDeadline", Description = "Voting deadline" },
        new() { Name = "UserName", Description = "Recipient's name" },
        new() { Name = "ActionUrl", Description = "Link to take action" }
    ];

    private IEnumerable<NotificationTemplateInfo> FilteredTemplates => templates
        .Where(t => string.IsNullOrEmpty(searchTerm) || 
                    t.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    t.Code.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(t => string.IsNullOrEmpty(selectedChannel) || t.Channel == selectedChannel)
        .Where(t => string.IsNullOrEmpty(selectedStatus) || 
                    (selectedStatus == "Active" && t.IsActive) ||
                    (selectedStatus == "Inactive" && !t.IsActive))
        .OrderBy(t => t.Code);

    protected override async Task OnInitializedAsync()
    {
        await LoadTemplates();
    }

    private async Task LoadTemplates()
    {
        isLoading = true;
        templates = await AppService.GetNotificationTemplatesAsync();
        isLoading = false;
    }

    private void OpenCreateModal()
    {
        editingTemplate = new NotificationTemplateInfo();
        isEditing = false;
        saveError = null;
        showTemplateModal = true;
    }

    private void EditTemplate(NotificationTemplateInfo template)
    {
        editingTemplate = new NotificationTemplateInfo
        {
            Id = template.Id,
            Code = template.Code,
            Name = template.Name,
            Description = template.Description,
            Type = template.Type,
            Channel = template.Channel,
            Subject = template.Subject,
            BodyTemplate = template.BodyTemplate,
            BodyHtmlTemplate = template.BodyHtmlTemplate
        };
        isEditing = true;
        saveError = null;
        showTemplateModal = true;
    }

    private void PreviewTemplate(NotificationTemplateInfo template)
    {
        previewTemplate = template;
        showPreviewModal = true;
    }

    private void CloseModal()
    {
        showTemplateModal = false;
        editingTemplate = new();
        saveError = null;
    }

    private void ClosePreviewModal()
    {
        showPreviewModal = false;
        previewTemplate = null;
    }

    private async Task SaveTemplate()
    {
        if (string.IsNullOrWhiteSpace(editingTemplate.Name))
        {
            saveError = "Template name is required";
            return;
        }
        if (string.IsNullOrWhiteSpace(editingTemplate.Code))
        {
            saveError = "Template code is required";
            return;
        }
        if (string.IsNullOrWhiteSpace(editingTemplate.Channel))
        {
            saveError = "Channel is required";
            return;
        }
        if (string.IsNullOrWhiteSpace(editingTemplate.Type))
        {
            saveError = "Type is required";
            return;
        }
        if (string.IsNullOrWhiteSpace(editingTemplate.BodyTemplate))
        {
            saveError = "Body template is required";
            return;
        }
        if (editingTemplate.Channel == "Email" && string.IsNullOrWhiteSpace(editingTemplate.Subject))
        {
            saveError = "Subject is required for email templates";
            return;
        }

        isSaving = true;
        saveError = null;
        
        try
        {
            var userId = AuthService.CurrentUser?.Id ?? Guid.Empty;
            ApiResponse result;

            if (isEditing)
            {
                result = await AppService.UpdateNotificationTemplateAsync(editingTemplate.Id, new UpdateTemplateRequest
                {
                    Name = editingTemplate.Name,
                    Description = editingTemplate.Description,
                    Subject = editingTemplate.Subject,
                    BodyTemplate = editingTemplate.BodyTemplate,
                    BodyHtmlTemplate = editingTemplate.BodyHtmlTemplate
                }, userId);
            }
            else
            {
                result = await AppService.CreateNotificationTemplateAsync(new CreateTemplateRequest
                {
                    Code = editingTemplate.Code,
                    Name = editingTemplate.Name,
                    Description = editingTemplate.Description,
                    Type = editingTemplate.Type,
                    Channel = editingTemplate.Channel,
                    Subject = editingTemplate.Subject,
                    BodyTemplate = editingTemplate.BodyTemplate,
                    BodyHtmlTemplate = editingTemplate.BodyHtmlTemplate
                }, userId);
            }

            if (result.Success)
            {
                CloseModal();
                await LoadTemplates();
            }
            else
            {
                saveError = result.Error ?? "Failed to save template";
            }
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ToggleTemplate(NotificationTemplateInfo template)
    {
        var result = await AppService.ToggleNotificationTemplateAsync(template.Id, !template.IsActive);
        if (result.Success)
        {
            await LoadTemplates();
        }
    }

    private static string GetChannelBadgeClass(string channel) => channel switch
    {
        "Email" => "badge-primary",
        "SMS" => "badge-success",
        "WhatsApp" => "badge-success",
        "InApp" => "badge-info",
        _ => "badge-gray"
    };

    private static string GetChannelIcon(string channel) => channel switch
    {
        "Email" => "mail",
        "SMS" => "sms",
        "WhatsApp" => "chat",
        "InApp" => "notifications",
        _ => "notifications"
    };

    private static string FormatType(string type) => type switch
    {
        "ApplicationSubmitted" => "App Submitted",
        "ApplicationApproved" => "App Approved",
        "ApplicationRejected" => "App Rejected",
        "ApplicationReturned" => "App Returned",
        "WorkflowAssigned" => "Workflow Assigned",
        "WorkflowSLAWarning" => "SLA Warning",
        "WorkflowSLABreached" => "SLA Breached",
        "CommitteeVoteRequired" => "Vote Required",
        "CommitteeDecisionMade" => "Committee Decision",
        "CreditCheckCompleted" => "Credit Check",
        "DocumentRequired" => "Doc Required",
        "SystemAlert" => "System Alert",
        _ => type
    };

    private class VariableInfo
    {
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
    }
}
