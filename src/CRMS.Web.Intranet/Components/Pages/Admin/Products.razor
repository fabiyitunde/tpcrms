@page "/admin/products"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SystemAdmin,RiskManager")]
@inject ApplicationService AppService
@inject AuthService AuthService

<PageTitle>Loan Products - CRMS</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Loan Products</h1>
        <p class="page-subtitle">Configure loan products and pricing</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenCreateModal">
        <span class="material-symbols-outlined" style="font-size: 18px;">add</span>
        Add Product
    </button>
</div>

<div class="products-grid">
    @foreach (var product in PagedProducts)
    {
        <div class="product-card @(!product.IsActive ? "inactive" : "")">
            <div class="product-card-header">
                <div>
                    <div style="font-size: var(--text-lg); font-weight: 600;">@product.Name</div>
                    <div style="font-size: var(--text-sm); color: var(--gray-500);">@product.Code</div>
                </div>
                <span class="badge @(product.IsActive ? "badge-success" : "badge-gray")">
                    @(product.IsActive ? "Active" : "Inactive")
                </span>
            </div>
            <div class="product-card-body">
                <div class="product-stat">
                    <span class="product-stat-label">Amount Range</span>
                    <span class="product-stat-value">₦@FormatAmount(product.MinAmount) - ₦@FormatAmount(product.MaxAmount)</span>
                </div>
                <div class="product-stat">
                    <span class="product-stat-label">Tenor</span>
                    <span class="product-stat-value">@product.MinTenorMonths - @product.MaxTenorMonths months</span>
                </div>
                <div class="product-stat">
                    <span class="product-stat-label">Base Rate</span>
                    <span class="product-stat-value">@product.BaseInterestRate% p.a.</span>
                </div>
                <div class="product-stat">
                    <span class="product-stat-label">Applications</span>
                    <span class="product-stat-value">@product.ApplicationCount active</span>
                </div>
            </div>
            <div class="product-card-footer">
                <button class="btn btn-outline btn-sm" @onclick="() => EditProduct(product)">
                    <span class="material-symbols-outlined" style="font-size: 16px;">edit</span>
                    Edit
                </button>
                <button class="btn btn-outline btn-sm" @onclick="() => OpenChecklistModal(product)">
                    <span class="material-symbols-outlined" style="font-size: 16px;">checklist</span>
                    Checklist
                </button>
                <button class="btn btn-ghost btn-sm" @onclick="() => ToggleProduct(product)" disabled="@isSaving">
                    <span class="material-symbols-outlined" style="font-size: 16px;">@(product.IsActive ? "pause" : "play_arrow")</span>
                    @(product.IsActive ? "Disable" : "Enable")
                </button>
            </div>
        </div>
    }
</div>

@if (TotalPages > 1)
{
    <div class="pagination-bar">
        <span class="pagination-info">@((currentPage - 1) * PageSize + 1)–@(Math.Min(currentPage * PageSize, products.Count)) of @products.Count</span>
        <div class="pagination-controls">
            <button class="btn btn-ghost btn-sm" @onclick="() => currentPage--" disabled="@(currentPage == 1)">
                <span class="material-symbols-outlined" style="font-size: 18px;">chevron_left</span>
            </button>
            <span style="font-size: var(--text-sm); padding: 0 var(--space-2);">@currentPage / @TotalPages</span>
            <button class="btn btn-ghost btn-sm" @onclick="() => currentPage++" disabled="@(currentPage == TotalPages)">
                <span class="material-symbols-outlined" style="font-size: 18px;">chevron_right</span>
            </button>
        </div>
    </div>
}

@if (showProductModal)
{
    <div class="modal-backdrop show" @onclick="CloseModal">
        <div class="modal" style="max-width: 600px;" @onclick:stopPropagation>
            <div class="modal-header">
                <h3 class="modal-title">@(isEditing ? "Edit Product" : "Add New Product")</h3>
                <button class="modal-close" @onclick="CloseModal">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="grid grid-cols-2 gap-4">
                    <div class="form-group">
                        <label class="form-label">Product Name *</label>
                        <input type="text" class="form-control" @bind="editingProduct.Name" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Product Code *</label>
                        <input type="text" class="form-control" @bind="editingProduct.Code" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Min Amount (₦) *</label>
                        <input type="number" class="form-control" @bind="editingProduct.MinAmount" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Max Amount (₦) *</label>
                        <input type="number" class="form-control" @bind="editingProduct.MaxAmount" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Min Tenor (Months) *</label>
                        <input type="number" class="form-control" @bind="editingProduct.MinTenorMonths" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Max Tenor (Months) *</label>
                        <input type="number" class="form-control" @bind="editingProduct.MaxTenorMonths" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Base Interest Rate (%) *</label>
                        <input type="number" step="0.01" class="form-control" @bind="editingProduct.BaseInterestRate" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Product Type</label>
                        <select class="form-control" @bind="editingProduct.ProductType">
                            <option value="TermLoan">Term Loan</option>
                            <option value="WorkingCapital">Working Capital</option>
                            <option value="AssetFinance">Asset Finance</option>
                            <option value="TradeFinance">Trade Finance</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Fineract Product ID</label>
                        <input type="number" class="form-control" @bind="editingProduct.FineractProductId" placeholder="e.g. 1" />
                        <small style="color: var(--gray-500);">Maps to core banking loan product. Leave blank for in-house schedule calculation.</small>
                    </div>
                    <div class="form-group" style="grid-column: span 2;">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="2" @bind="editingProduct.Description"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                @if (!string.IsNullOrEmpty(saveError))
                {
                    <div class="alert alert-danger" style="margin: 0; flex: 1; font-size: var(--text-sm);">@saveError</div>
                }
                <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveProduct" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="spinner"></span>
                    }
                    @(isEditing ? "Update" : "Create") Product
                </button>
            </div>
        </div>
    </div>
}

@if (showChecklistModal)
{
    <div class="modal-backdrop show" @onclick="CloseChecklistModal">
        <div class="modal" style="max-width: 860px;" @onclick:stopPropagation>
            <div class="modal-header">
                <div>
                    <h3 class="modal-title">Disbursement Checklist — @checklistProductName</h3>
                    <p style="font-size: var(--text-sm); color: var(--gray-500); margin: 0;">Conditions Precedent (CP) and Conditions Subsequent (CS) template items</p>
                </div>
                <button class="modal-close" @onclick="CloseChecklistModal">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="modal-body" style="padding: 0;">
                @if (!string.IsNullOrEmpty(checklistError))
                {
                    <div class="alert alert-danger" style="margin: var(--space-4); margin-bottom: 0;">@checklistError</div>
                }
                <table class="table" style="margin: 0;">
                    <thead>
                        <tr>
                            <th style="width:40px;">#</th>
                            <th>Item Name</th>
                            <th style="width:80px;">Type</th>
                            <th style="width:80px;">Mandatory</th>
                            <th style="width:100px;">Due Days</th>
                            <th style="width:80px;">Status</th>
                            <th style="width:110px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (checklistItems.Count == 0)
                        {
                            <tr><td colspan="7" style="text-align:center; color:var(--gray-400); padding: var(--space-6);">No checklist items configured. Click Add Item to get started.</td></tr>
                        }
                        @foreach (var item in checklistItems.OrderBy(i => i.SortOrder))
                        {
                            <tr>
                                <td>@item.SortOrder</td>
                                <td>
                                    <div style="font-weight:500;">@item.ItemName</div>
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        <div style="font-size:var(--text-xs); color:var(--gray-500);">@item.Description</div>
                                    }
                                </td>
                                <td><span class="badge @(item.ConditionType == "Precedent" ? "badge-primary" : "badge-warning")">@item.ConditionType[..2]</span></td>
                                <td><span class="badge @(item.IsMandatory ? "badge-danger" : "badge-gray")">@(item.IsMandatory ? "Yes" : "No")</span></td>
                                <td>@(item.ConditionType == "Subsequent" ? $"{item.SubsequentDueDays}d" : "—")</td>
                                <td><span class="badge @(item.IsActive ? "badge-success" : "badge-gray")">@(item.IsActive ? "Active" : "Inactive")</span></td>
                                <td style="text-align:right;">
                                    <button class="btn btn-ghost btn-sm" @onclick="() => EditChecklistItem(item)">
                                        <span class="material-symbols-outlined" style="font-size:15px;">edit</span>
                                    </button>
                                    <button class="btn btn-ghost btn-sm" @onclick="() => RemoveChecklistItem(item.Id)" disabled="@isChecklistSaving">
                                        <span class="material-symbols-outlined" style="font-size:15px; color:var(--error);">delete</span>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" @onclick="OpenAddChecklistItem" disabled="@isChecklistSaving">
                    <span class="material-symbols-outlined" style="font-size:16px;">add</span>
                    Add Item
                </button>
                <button class="btn btn-secondary" @onclick="CloseChecklistModal">Close</button>
            </div>
        </div>
    </div>
}

@if (showChecklistItemModal)
{
    <div class="modal-backdrop show" @onclick="CloseChecklistItemModal">
        <div class="modal" style="max-width: 560px;" @onclick:stopPropagation>
            <div class="modal-header">
                <h3 class="modal-title">@(isEditingChecklistItem ? "Edit" : "Add") Checklist Item</h3>
                <button class="modal-close" @onclick="CloseChecklistItemModal">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="grid grid-cols-2 gap-4">
                    <div class="form-group" style="grid-column: span 2;">
                        <label class="form-label">Item Name *</label>
                        <input type="text" class="form-control" @bind="editingChecklistItem.ItemName" />
                    </div>
                    <div class="form-group" style="grid-column: span 2;">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="2" @bind="editingChecklistItem.Description"></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Condition Type *</label>
                        <select class="form-control" @bind="editingChecklistItem.ConditionType">
                            <option value="Precedent">Precedent (CP)</option>
                            <option value="Subsequent">Subsequent (CS)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Sort Order</label>
                        <input type="number" class="form-control" @bind="editingChecklistItem.SortOrder" />
                    </div>
                    @if (editingChecklistItem.ConditionType == "Subsequent")
                    {
                        <div class="form-group">
                            <label class="form-label">Due Days after Disbursement *</label>
                            <input type="number" class="form-control" @bind="editingChecklistItem.SubsequentDueDays" />
                        </div>
                        <div></div>
                    }
                    <div class="form-group">
                        <label class="form-label" style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                            <input type="checkbox" @bind="editingChecklistItem.IsMandatory" />
                            Mandatory
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="form-label" style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                            <input type="checkbox" @bind="editingChecklistItem.CanBeWaived" />
                            Can Be Waived
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="form-label" style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                            <input type="checkbox" @bind="editingChecklistItem.RequiresDocumentUpload" />
                            Requires Document Upload
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="form-label" style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                            <input type="checkbox" @bind="editingChecklistItem.RequiresLegalRatification" />
                            Requires Legal Ratification
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                @if (!string.IsNullOrEmpty(checklistItemError))
                {
                    <div class="alert alert-danger" style="margin: 0; flex: 1; font-size: var(--text-sm);">@checklistItemError</div>
                }
                <button class="btn btn-secondary" @onclick="CloseChecklistItemModal">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveChecklistItem" disabled="@isChecklistSaving">
                    @if (isChecklistSaving)
                    {
                        <span class="spinner"></span>
                    }
                    @(isEditingChecklistItem ? "Update" : "Add") Item
                </button>
            </div>
        </div>
    </div>
}

<style>
    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: var(--space-6);
    }
    
    .product-card {
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-xl);
        overflow: hidden;
        transition: all var(--transition-fast);
    }
    
    .product-card:hover {
        box-shadow: var(--shadow-md);
    }
    
    .product-card.inactive {
        opacity: 0.7;
    }
    
    .product-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: var(--space-5);
        background: var(--gray-50);
        border-bottom: 1px solid var(--gray-100);
    }
    
    .product-card-body {
        padding: var(--space-5);
    }
    
    .product-stat {
        display: flex;
        justify-content: space-between;
        padding: var(--space-2) 0;
        border-bottom: 1px solid var(--gray-100);
    }
    
    .product-stat:last-child {
        border-bottom: none;
    }
    
    .product-stat-label {
        font-size: var(--text-sm);
        color: var(--gray-500);
    }
    
    .product-stat-value {
        font-size: var(--text-sm);
        font-weight: 500;
    }
    
    .product-card-footer {
        display: flex;
        justify-content: flex-end;
        gap: var(--space-2);
        padding: var(--space-4);
        background: var(--gray-50);
        border-top: 1px solid var(--gray-100);
    }

    .pagination-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--space-3) var(--space-4);
        margin-top: var(--space-4);
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-xl);
    }
    .pagination-info { font-size: var(--text-sm); color: var(--gray-500); }
    .pagination-controls { display: flex; align-items: center; gap: var(--space-1); }
</style>

@code {
    private List<ProductModel> products = [];
    private bool showProductModal;
    private bool isEditing;
    private bool isSaving;
    private bool isLoading = true;
    private string? saveError;
    private ProductModel editingProduct = new();
    private int currentPage = 1;
    private const int PageSize = 15;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(products.Count / (double)PageSize));
    private IEnumerable<ProductModel> PagedProducts => products.Skip((currentPage - 1) * PageSize).Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        isLoading = true;
        currentPage = 1;
        try
        {
            var dbProducts = await AppService.GetAllLoanProductsAsync();
            if (dbProducts.Count > 0)
            {
                products = dbProducts.Select(p => new ProductModel
                {
                    Id = p.Id,
                    Name = p.Name,
                    Code = p.Code,
                    MinAmount = p.MinAmount,
                    MaxAmount = p.MaxAmount,
                    MinTenorMonths = p.MinTenorMonths,
                    MaxTenorMonths = p.MaxTenorMonths,
                    BaseInterestRate = p.BaseInterestRate,
                    IsActive = p.IsActive,
                    FineractProductId = p.FineractProductId
                }).ToList();
            }
            else if (AuthService.CurrentUser?.Username == "admin")
            {
                // Mock data only for the seeded admin demo account
                products =
                [
                    new() { Id = Guid.NewGuid(), Name = "Corporate Term Loan", Code = "CTL", MinAmount = 10_000_000, MaxAmount = 5_000_000_000, MinTenorMonths = 12, MaxTenorMonths = 60, BaseInterestRate = 18.5m, ProductType = "TermLoan", IsActive = true, ApplicationCount = 45 },
                    new() { Id = Guid.NewGuid(), Name = "Working Capital Finance", Code = "WCF", MinAmount = 5_000_000, MaxAmount = 500_000_000, MinTenorMonths = 3, MaxTenorMonths = 12, BaseInterestRate = 20m, ProductType = "WorkingCapital", IsActive = true, ApplicationCount = 62 },
                    new() { Id = Guid.NewGuid(), Name = "Asset Finance", Code = "ASF", MinAmount = 20_000_000, MaxAmount = 2_000_000_000, MinTenorMonths = 24, MaxTenorMonths = 84, BaseInterestRate = 17m, ProductType = "AssetFinance", IsActive = true, ApplicationCount = 28 },
                    new() { Id = Guid.NewGuid(), Name = "Trade Finance", Code = "TRF", MinAmount = 10_000_000, MaxAmount = 1_000_000_000, MinTenorMonths = 1, MaxTenorMonths = 6, BaseInterestRate = 22m, ProductType = "TradeFinance", IsActive = true, ApplicationCount = 21 },
                    new() { Id = Guid.NewGuid(), Name = "Agricultural Loan", Code = "AGL", MinAmount = 5_000_000, MaxAmount = 500_000_000, MinTenorMonths = 12, MaxTenorMonths = 36, BaseInterestRate = 12m, ProductType = "TermLoan", IsActive = false, ApplicationCount = 8 }
                ];
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreateModal()
    {
        editingProduct = new();
        isEditing = false;
        showProductModal = true;
    }

    private void EditProduct(ProductModel product)
    {
        editingProduct = new()
        {
            Id = product.Id,
            Name = product.Name,
            Code = product.Code,
            MinAmount = product.MinAmount,
            MaxAmount = product.MaxAmount,
            MinTenorMonths = product.MinTenorMonths,
            MaxTenorMonths = product.MaxTenorMonths,
            BaseInterestRate = product.BaseInterestRate,
            ProductType = product.ProductType,
            Description = product.Description,
            FineractProductId = product.FineractProductId
        };
        isEditing = true;
        showProductModal = true;
    }

    private void CloseModal()
    {
        showProductModal = false;
        editingProduct = new();
        saveError = null;
    }

    private async Task SaveProduct()
    {
        isSaving = true;
        saveError = null;
        try
        {
            ApiResponse result;
            if (isEditing)
            {
                result = await AppService.UpdateLoanProductAsync(
                    editingProduct.Id,
                    editingProduct.Name,
                    editingProduct.Description,
                    editingProduct.MinAmount,
                    editingProduct.MaxAmount,
                    editingProduct.MinTenorMonths,
                    editingProduct.MaxTenorMonths,
                    editingProduct.FineractProductId);
            }
            else
            {
                result = await AppService.CreateLoanProductAsync(
                    editingProduct.Code,
                    editingProduct.Name,
                    editingProduct.Description ?? string.Empty,
                    editingProduct.MinAmount,
                    editingProduct.MaxAmount,
                    editingProduct.MinTenorMonths,
                    editingProduct.MaxTenorMonths);
            }

            if (result.Success)
            {
                CloseModal();
                await LoadProductsAsync();
            }
            else
            {
                saveError = result.Error ?? "Failed to save product";
            }
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ToggleProduct(ProductModel product)
    {
        var result = await AppService.ToggleLoanProductAsync(product.Id, product.IsActive);
        if (result.Success)
            await LoadProductsAsync();
    }

    private static string FormatAmount(decimal amount)
    {
        if (amount >= 1_000_000_000) return $"{amount / 1_000_000_000:0.##}B";
        if (amount >= 1_000_000) return $"{amount / 1_000_000:0.##}M";
        return $"{amount:N0}";
    }

    // ---- Checklist Template Management ----
    private bool showChecklistModal;
    private bool showChecklistItemModal;
    private bool isEditingChecklistItem;
    private bool isChecklistSaving;
    private string? checklistProductName;
    private Guid checklistProductId;
    private string? checklistError;
    private string? checklistItemError;
    private List<ChecklistTemplateItemModel> checklistItems = [];
    private ChecklistTemplateItemModel editingChecklistItem = new();

    private async Task OpenChecklistModal(ProductModel product)
    {
        checklistProductId = product.Id;
        checklistProductName = product.Name;
        checklistError = null;
        checklistItems = await AppService.GetChecklistTemplateItemsAsync(product.Id);
        showChecklistModal = true;
    }

    private void CloseChecklistModal()
    {
        showChecklistModal = false;
        checklistError = null;
        checklistItems = [];
    }

    private void OpenAddChecklistItem()
    {
        editingChecklistItem = new ChecklistTemplateItemModel
        {
            LoanProductId = checklistProductId,
            SortOrder = checklistItems.Count > 0 ? checklistItems.Max(i => i.SortOrder) + 10 : 10
        };
        isEditingChecklistItem = false;
        checklistItemError = null;
        showChecklistItemModal = true;
    }

    private void EditChecklistItem(ChecklistTemplateItemModel item)
    {
        editingChecklistItem = new ChecklistTemplateItemModel
        {
            Id = item.Id,
            LoanProductId = item.LoanProductId,
            ItemName = item.ItemName,
            Description = item.Description,
            IsMandatory = item.IsMandatory,
            ConditionType = item.ConditionType,
            SubsequentDueDays = item.SubsequentDueDays,
            RequiresDocumentUpload = item.RequiresDocumentUpload,
            RequiresLegalRatification = item.RequiresLegalRatification,
            CanBeWaived = item.CanBeWaived,
            SortOrder = item.SortOrder,
            IsActive = item.IsActive
        };
        isEditingChecklistItem = true;
        checklistItemError = null;
        showChecklistItemModal = true;
    }

    private void CloseChecklistItemModal()
    {
        showChecklistItemModal = false;
        checklistItemError = null;
    }

    private async Task SaveChecklistItem()
    {
        isChecklistSaving = true;
        checklistItemError = null;
        try
        {
            var userRole = AuthService.CurrentUser?.PrimaryRole ?? "SystemAdmin";
            ApiResponse result;
            if (isEditingChecklistItem)
                result = await AppService.UpdateChecklistTemplateItemAsync(checklistProductId, userRole, editingChecklistItem);
            else
                result = await AppService.AddChecklistTemplateItemAsync(checklistProductId, userRole, editingChecklistItem);

            if (result.Success)
            {
                showChecklistItemModal = false;
                checklistItems = await AppService.GetChecklistTemplateItemsAsync(checklistProductId);
            }
            else
            {
                checklistItemError = result.Error ?? "Failed to save item";
            }
        }
        finally
        {
            isChecklistSaving = false;
        }
    }

    private async Task RemoveChecklistItem(Guid itemId)
    {
        isChecklistSaving = true;
        checklistError = null;
        try
        {
            var userRole = AuthService.CurrentUser?.PrimaryRole ?? "SystemAdmin";
            var result = await AppService.RemoveChecklistTemplateItemAsync(checklistProductId, itemId, userRole);
            if (result.Success)
                checklistItems = await AppService.GetChecklistTemplateItemsAsync(checklistProductId);
            else
                checklistError = result.Error ?? "Failed to remove item";
        }
        finally
        {
            isChecklistSaving = false;
        }
    }

