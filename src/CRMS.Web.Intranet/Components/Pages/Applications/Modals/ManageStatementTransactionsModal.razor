@using CRMS.Web.Intranet.Models
@inject CRMS.Web.Intranet.Services.ApplicationService AppService

<div class="modal-backdrop show" @onclick="Close">
    <div class="modal" style="max-width: 1050px; max-height: 92vh; display: flex; flex-direction: column;" @onclick:stopPropagation>
        <div class="modal-header">
            <div>
                <h3 class="modal-title">
                    <span class="material-symbols-outlined" style="font-size: 20px; vertical-align: middle; margin-right: var(--space-2);">table_rows</span>
                    Enter Transactions — @Statement.BankName
                </h3>
                <div style="font-size: var(--text-sm); color: var(--gray-500); margin-top: 2px;">
                    @Statement.AccountNumber &nbsp;•&nbsp; @Statement.AccountName &nbsp;•&nbsp;
                    @Statement.PeriodStart.ToString("dd MMM yyyy") – @Statement.PeriodEnd.ToString("dd MMM yyyy")
                </div>
            </div>
            <button class="modal-close" @onclick="Close">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <div style="padding: var(--space-4); border-bottom: 1px solid var(--gray-200);">
            <!-- Balance summary bar -->
            <div style="display: flex; gap: var(--space-3); flex-wrap: wrap; align-items: stretch;">
                <div class="stat-box" style="min-width: 140px;">
                    <span class="stat-label">Opening Balance</span>
                    <span class="stat-value">₦@FormatAmt(Statement.OpeningBalance)</span>
                </div>
                <div class="stat-box" style="min-width: 140px;">
                    <span class="stat-label">@(ExistingTransactions?.Any() == true ? "New Credits" : "Total Credits")</span>
                    <span class="stat-value" style="color: var(--success-600);">₦@FormatAmt(TotalCredits)</span>
                </div>
                <div class="stat-box" style="min-width: 140px;">
                    <span class="stat-label">@(ExistingTransactions?.Any() == true ? "New Debits" : "Total Debits")</span>
                    <span class="stat-value" style="color: var(--danger-600);">₦@FormatAmt(TotalDebits)</span>
                </div>
                <div class="stat-box" style="min-width: 160px; border-color: @ReconciliationBorderColor; background: @ReconciliationBgColor;">
                    <span class="stat-label">Computed Closing</span>
                    <span class="stat-value" style="color: @ReconciliationTextColor;">
                        ₦@FormatAmt(ComputedClosing)
                        @if (rows.Any() && IsReconciled)
                        {
                            <span class="material-symbols-outlined" style="font-size: 16px; vertical-align: middle; margin-left: 4px;">check_circle</span>
                        }
                    </span>
                </div>
                <div class="stat-box" style="min-width: 140px;">
                    <span class="stat-label">Expected Closing</span>
                    <span class="stat-value">₦@FormatAmt(Statement.ClosingBalance)</span>
                </div>
                @if (rows.Any() && !IsReconciled)
                {
                    <div class="stat-box" style="min-width: 140px; border-color: var(--warning-300); background: var(--warning-50);">
                        <span class="stat-label">Discrepancy</span>
                        <span class="stat-value" style="color: var(--warning-700);">₦@FormatAmt(Math.Abs(ComputedClosing - Statement.ClosingBalance))</span>
                    </div>
                }
            </div>
        </div>

        <div style="overflow-y: auto; flex: 1; min-height: 0; padding: var(--space-4);">
            @if (!string.IsNullOrEmpty(ParseMessage))
            {
                bool parsedOk = rows.Any() && PreloadedTransactions?.Any() == true;
                <div class="alert @(parsedOk ? "alert-success" : "alert-warning") mb-3" style="padding: var(--space-2) var(--space-3); font-size: var(--text-sm);">
                    <span class="material-symbols-outlined" style="font-size: 16px; vertical-align: middle;">@(parsedOk ? "check_circle" : "info")</span>
                    @ParseMessage
                    @if (parsedOk)
                    {
                        <span style="margin-left: var(--space-2); color: var(--gray-500);">Review the rows below and correct any errors before saving.</span>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger mb-3">
                    <span class="material-symbols-outlined" style="font-size: 16px; vertical-align: middle;">error</span>
                    @error
                </div>
            }

            @if (!IsReconciled && rows.Any(r => r.DebitAmount > 0 || r.CreditAmount > 0))
            {
                <div class="alert alert-warning mb-3" style="padding: var(--space-2) var(--space-3); font-size: var(--text-sm);">
                    <span class="material-symbols-outlined" style="font-size: 16px; vertical-align: middle;">warning</span>
                    Statement is not reconciled — computed closing does not match expected. You can still save and enter more transactions later.
                </div>
            }

            <table class="table" style="font-size: var(--text-sm);">
                <thead>
                    <tr>
                        <th style="width: 130px;">Date</th>
                        <th>Description</th>
                        <th style="width: 120px;">Reference</th>
                        <th style="width: 140px; text-align: right;">Debit (₦)</th>
                        <th style="width: 140px; text-align: right;">Credit (₦)</th>
                        <th style="width: 150px; text-align: right;">Running Balance</th>
                        <th style="width: 42px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (ExistingTransactions?.Any() == true)
                    {
                        <tr>
                            <td colspan="7" style="background: var(--gray-50); padding: 6px 12px; font-size: var(--text-xs); color: var(--gray-500); font-weight: 500; border-bottom: 2px solid var(--gray-200);">
                                <span class="material-symbols-outlined" style="font-size: 13px; vertical-align: middle; margin-right: 4px;">lock</span>
                                @ExistingTransactions.Count previously saved transaction(s) — read only
                            </td>
                        </tr>
                        @foreach (var existing in ExistingTransactions.OrderBy(t => t.Date))
                        {
                            <tr style="background: var(--gray-50); color: var(--gray-500);">
                                <td>@existing.Date.ToString("yyyy-MM-dd")</td>
                                <td>@existing.Description</td>
                                <td>@existing.Reference</td>
                                <td style="text-align: right;">@(existing.Type == "Debit" ? FormatAmt(existing.Amount) : "")</td>
                                <td style="text-align: right;">@(existing.Type == "Credit" ? FormatAmt(existing.Amount) : "")</td>
                                <td style="text-align: right; font-weight: 500;">₦@FormatAmt(existing.RunningBalance)</td>
                                <td></td>
                            </tr>
                        }
                        <tr>
                            <td colspan="7" style="background: var(--primary-50); padding: 6px 12px; font-size: var(--text-xs); color: var(--primary-700); font-weight: 500; border-top: 2px solid var(--primary-200);">
                                <span class="material-symbols-outlined" style="font-size: 13px; vertical-align: middle; margin-right: 4px;">add_circle</span>
                                New transactions — continuing from ₦@FormatAmt(BaseBalance)
                            </td>
                        </tr>
                    }
                    @for (var i = 0; i < rows.Count; i++)
                    {
                        var row = rows[i];
                        var idx = i;
                        var runBal = ComputeRunningBalance(i);

                        <tr>
                            <td>
                                <input type="date" class="form-control form-control-sm"
                                       value="@row.Date.ToString("yyyy-MM-dd")"
                                       min="@Statement.PeriodStart.ToString("yyyy-MM-dd")"
                                       max="@Statement.PeriodEnd.ToString("yyyy-MM-dd")"
                                       @onchange="e => OnDateChanged(row, e.Value?.ToString())" />
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                       @bind="row.Description" @bind:event="oninput"
                                       placeholder="Transaction description" />
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                       @bind="row.Reference" @bind:event="oninput"
                                       placeholder="Optional" />
                            </td>
                            <td>
                                <input type="number" class="form-control form-control-sm" style="text-align: right;"
                                       value="@(row.DebitAmount > 0 ? row.DebitAmount.Value.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) : "")"
                                       step="0.01" min="0"
                                       placeholder="0.00"
                                       @onchange="e => OnDebitChanged(row, e.Value?.ToString())" />
                            </td>
                            <td>
                                <input type="number" class="form-control form-control-sm" style="text-align: right;"
                                       value="@(row.CreditAmount > 0 ? row.CreditAmount.Value.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) : "")"
                                       step="0.01" min="0"
                                       placeholder="0.00"
                                       @onchange="e => OnCreditChanged(row, e.Value?.ToString())" />
                            </td>
                            <td style="text-align: right; font-weight: 500; color: @(runBal < 0 ? "var(--danger-600)" : "var(--gray-700)"); vertical-align: middle;">
                                ₦@FormatAmt(runBal)
                            </td>
                            <td style="vertical-align: middle;">
                                <button type="button" class="btn btn-sm btn-ghost" style="color: var(--danger-500); padding: 4px;"
                                        @onclick="() => RemoveRow(idx)" title="Delete row">
                                    <span class="material-symbols-outlined" style="font-size: 16px;">delete</span>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <button type="button" class="btn btn-outline btn-sm" style="margin-top: var(--space-2);" @onclick="AddRow">
                <span class="material-symbols-outlined" style="font-size: 16px;">add</span>
                Add Row
            </button>
        </div>

        <div class="modal-footer">
            <div style="font-size: var(--text-sm); color: var(--gray-500); display: flex; align-items: center; gap: var(--space-2);">
                @rows.Count transaction(s)
                @if (rows.Any())
                {
                    if (IsReconciled)
                    {
                        <span class="badge badge-success">Reconciled</span>
                    }
                    else
                    {
                        <span class="badge badge-warning">Not Reconciled</span>
                    }
                }
            </div>
            <button type="button" class="btn btn-secondary" @onclick="Close" disabled="@isSaving">Cancel</button>
            <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 2px;">
                <button type="button" class="btn btn-primary" @onclick="Save" disabled="@(!CanSave || isSaving)">
                    @if (isSaving)
                    {
                        <span class="spinner"></span>
                    }
                    Save @rows.Count Transaction(s)
                </button>
                @if (!CanSave && rows.Any())
                {
                    <span style="font-size: var(--text-xs); color: var(--gray-400);">All rows need a description and at least one amount.</span>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public BankStatementInfo Statement { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnClose { get; set; }
    [Parameter, EditorRequired] public EventCallback OnSuccess { get; set; }
    /// <summary>Pre-populated from file parsing. When set, rows are seeded from this list instead of starting empty.</summary>
    [Parameter] public List<StatementTransactionRow>? PreloadedTransactions { get; set; }
    /// <summary>Optional message about the parse result to display to the user.</summary>
    [Parameter] public string? ParseMessage { get; set; }
    /// <summary>Already-saved transactions for this statement (shown read-only for context when adding more).</summary>
    [Parameter] public List<StatementTransactionInfo>? ExistingTransactions { get; set; }

    private List<StatementTransactionRow> rows = [];
    private bool isSaving;
    private string? error;

    /// <summary>Running balance after all already-saved transactions; new rows continue from here.</summary>
    private decimal BaseBalance => ExistingTransactions?.Any() == true
        ? ExistingTransactions.OrderBy(t => t.Date).Last().RunningBalance
        : Statement.OpeningBalance;

    private decimal TotalCredits => rows.Sum(r => r.CreditAmount ?? 0m);
    private decimal TotalDebits => rows.Sum(r => r.DebitAmount ?? 0m);
    private decimal ComputedClosing => BaseBalance + TotalCredits - TotalDebits;
    private bool IsReconciled => Math.Abs(ComputedClosing - Statement.ClosingBalance) <= 1.0m;

    private string ReconciliationBorderColor => rows.Any()
        ? (IsReconciled ? "var(--success-300)" : "var(--warning-300)")
        : "var(--gray-200)";
    private string ReconciliationBgColor => rows.Any()
        ? (IsReconciled ? "var(--success-50)" : "var(--warning-50)")
        : "white";
    private string ReconciliationTextColor => rows.Any()
        ? (IsReconciled ? "var(--success-700)" : "var(--warning-700)")
        : "inherit";

    private bool CanSave => rows.Any() &&
        rows.All(r =>
            !string.IsNullOrWhiteSpace(r.Description) &&
            ((r.DebitAmount ?? 0m) > 0 || (r.CreditAmount ?? 0m) > 0));

    protected override void OnInitialized()
    {
        if (PreloadedTransactions?.Any() == true)
            rows = PreloadedTransactions.Select(r => new StatementTransactionRow
            {
                Date = r.Date,
                Description = r.Description,
                Reference = r.Reference,
                DebitAmount = r.DebitAmount,
                CreditAmount = r.CreditAmount,
                RunningBalance = r.RunningBalance
            }).ToList();
        else
            AddRow();
    }

    private decimal ComputeRunningBalance(int upToIndex)
    {
        var bal = BaseBalance;
        for (var j = 0; j <= upToIndex; j++)
            bal += (rows[j].CreditAmount ?? 0m) - (rows[j].DebitAmount ?? 0m);
        return bal;
    }

    private void AddRow()
    {
        rows.Add(new StatementTransactionRow
        {
            Date = rows.Any() ? rows.Last().Date : Statement.PeriodStart.Date
        });
    }

    private void RemoveRow(int index)
    {
        if (index >= 0 && index < rows.Count)
            rows.RemoveAt(index);
    }

    private void OnDateChanged(StatementTransactionRow row, string? val)
    {
        if (DateTime.TryParse(val, out var d))
            row.Date = d;
    }

    private void OnDebitChanged(StatementTransactionRow row, string? val)
    {
        var amount = ParseDecimal(val);
        row.DebitAmount = amount > 0 ? amount : null;
        if (row.DebitAmount > 0)
            row.CreditAmount = null;
        StateHasChanged();
    }

    private void OnCreditChanged(StatementTransactionRow row, string? val)
    {
        var amount = ParseDecimal(val);
        row.CreditAmount = amount > 0 ? amount : null;
        if (row.CreditAmount > 0)
            row.DebitAmount = null;
        StateHasChanged();
    }

    private async Task Save()
    {
        error = null;
        isSaving = true;
        StateHasChanged();
        try
        {
            // Stamp final running balances before sending (continue from last saved transaction)
            decimal bal = BaseBalance;
            foreach (var r in rows)
            {
                bal += (r.CreditAmount ?? 0m) - (r.DebitAmount ?? 0m);
                r.RunningBalance = bal;
            }

            var result = await AppService.AddStatementTransactionsAsync(Statement.Id, rows);
            if (result.Success)
            {
                // Always refresh the parent so the statement list reflects what was saved.
                // If some rows were skipped (outside period) the backend still saved the valid ones.
                await OnSuccess.InvokeAsync();
            }
            else
                error = result.Error ?? "Failed to save transactions.";
        }
        catch (Exception ex)
        {
            error = $"Unexpected error: {ex.Message}";
        }
        finally { isSaving = false; }
    }

    private Task Close() => OnClose.InvokeAsync();

    private static decimal? ParseDecimal(string? val)
    {
        if (string.IsNullOrWhiteSpace(val)) return null;
        return decimal.TryParse(val, System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var d) && d > 0 ? d : null;
    }

    private static string FormatAmt(decimal amount) =>
        amount >= 1_000_000_000 ? $"{amount / 1_000_000_000:N2}B"
        : amount >= 1_000_000 ? $"{amount / 1_000_000:N2}M"
        : amount >= 1_000 ? $"{amount / 1_000:N2}K"
        : amount.ToString("N0");
}
