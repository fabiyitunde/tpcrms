@using CRMS.Web.Intranet.Models

<div class="card mb-4">
    <div class="card-header">
        <h3 class="card-title">
            <span class="material-symbols-outlined" style="font-size: 20px; vertical-align: middle; margin-right: var(--space-2);">account_balance</span>
            Own Bank Statement
        </h3>
        <span class="badge badge-primary">Internal</span>
    </div>
    <div class="card-body" style="padding: 0;">
        @{
            var internal_ = Statements.FirstOrDefault(s => s.IsInternal);
        }
        @if (internal_ == null)
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <span class="material-symbols-outlined">receipt_long</span>
                </div>
                <div class="empty-state-title">No internal statement</div>
                <div class="empty-state-text">The 6-month bank statement will be auto-fetched from core banking when the application is created.</div>
            </div>
        }
        else
        {
            <div style="padding: var(--space-4);">

                @* ── Header: bank info left │ badges + actions right ── *@
                <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: var(--space-4); margin-bottom: var(--space-4);">
                    <div>
                        <div style="font-weight: 600; font-size: var(--text-base); color: var(--gray-900);">@internal_.BankName</div>
                        <div style="font-size: var(--text-sm); color: var(--gray-500); margin-top: var(--space-1);">
                            @internal_.AccountNumber &nbsp;&bull;&nbsp; @internal_.AccountName
                        </div>
                        <div style="display: flex; gap: var(--space-2); margin-top: var(--space-2);">
                            @TrustBadge(internal_.TrustWeight, internal_.IsInternal)
                            @AnalysisBadge(internal_.AnalysisStatus)
                        </div>
                    </div>
                    <div style="display: flex; gap: var(--space-2); flex-shrink: 0; align-items: center;">
                        <button class="btn btn-sm btn-outline" @onclick="() => OnViewTransactions.InvokeAsync(internal_.Id)">
                            <span class="material-symbols-outlined" style="font-size: 16px;">list</span>
                            View Transactions
                        </button>
                        @if (internal_.TransactionCount == 0 && CanAnalyzeStatements)
                        {
                            <button class="btn btn-sm btn-outline" @onclick="HandleRefetch" disabled="@isRefetching">
                                @if (isRefetching)
                                {
                                    <span class="spinner-border spinner-border-sm" style="width: 14px; height: 14px; border-width: 2px;" role="status"></span>
                                    <span style="margin-left: var(--space-1);">Refreshing…</span>
                                }
                                else
                                {
                                    <span class="material-symbols-outlined" style="font-size: 16px;">refresh</span>
                                    <span>Refresh from Core Banking</span>
                                }
                            </button>
                        }
                        @if (internal_.AnalysisStatus == "Pending" && internal_.TransactionCount > 0 && CanAnalyzeStatements)
                        {
                            <button class="btn btn-sm btn-outline" @onclick="() => OnAnalyze.InvokeAsync(internal_.Id)">
                                <span class="material-symbols-outlined" style="font-size: 16px;">analytics</span>
                                Analyze
                            </button>
                        }
                    </div>
                </div>

                @* ── Coverage stats: period / months / transactions ── *@
                <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 1px; background: var(--gray-200); border: 1px solid var(--gray-200); border-radius: var(--radius-md); overflow: hidden; margin-bottom: var(--space-3);">
                    <div style="background: var(--gray-50); padding: var(--space-3);">
                        <div style="font-size: var(--text-xs); color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: var(--space-1);">Period</div>
                        <div style="font-weight: 600; font-size: var(--text-sm); color: var(--gray-900);">@internal_.PeriodStart.ToString("MMM yyyy") – @internal_.PeriodEnd.ToString("MMM yyyy")</div>
                    </div>
                    <div style="background: var(--gray-50); padding: var(--space-3);">
                        <div style="font-size: var(--text-xs); color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: var(--space-1);">Months Covered</div>
                        <div style="font-weight: 600; font-size: var(--text-sm); color: var(--gray-900);">@internal_.MonthsCovered months</div>
                    </div>
                    <div style="background: var(--gray-50); padding: var(--space-3);">
                        <div style="font-size: var(--text-xs); color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: var(--space-1);">Transactions</div>
                        <div style="font-weight: 600; font-size: var(--text-sm); color: var(--gray-900);">@internal_.TransactionCount.ToString("N0")</div>
                    </div>
                </div>

                @* ── Financial stats: only shown after analysis ── *@
                @if (internal_.TotalCredits.HasValue)
                {
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 1px; background: var(--gray-200); border: 1px solid var(--gray-200); border-radius: var(--radius-md); overflow: hidden;">
                        <div style="background: white; padding: var(--space-3);">
                            <div style="font-size: var(--text-xs); color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: var(--space-1);">Total Credits</div>
                            <div style="font-weight: 700; font-size: var(--text-base); color: var(--success-700);">₦@FormatAmount(internal_.TotalCredits.Value)</div>
                        </div>
                        <div style="background: white; padding: var(--space-3);">
                            <div style="font-size: var(--text-xs); color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: var(--space-1);">Total Debits</div>
                            <div style="font-weight: 700; font-size: var(--text-base); color: var(--danger-600);">₦@FormatAmount(internal_.TotalDebits ?? 0)</div>
                        </div>
                        <div style="background: white; padding: var(--space-3);">
                            <div style="font-size: var(--text-xs); color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: var(--space-1);">Avg Monthly Balance</div>
                            <div style="font-weight: 700; font-size: var(--text-base); color: var(--gray-900);">₦@FormatAmount(internal_.AverageMonthlyBalance ?? 0)</div>
                        </div>
                        @if (internal_.BouncedTransactions.HasValue)
                        {
                            <div style="background: white; padding: var(--space-3);">
                                <div style="font-size: var(--text-xs); color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: var(--space-1);">Bounced</div>
                                <div style="font-weight: 700; font-size: var(--text-base); color: @(internal_.BouncedTransactions > 0 ? "var(--danger-600)" : "var(--gray-900)");">@internal_.BouncedTransactions</div>
                            </div>
                        }
                        @if (internal_.GamblingTransactions.HasValue)
                        {
                            <div style="background: white; padding: var(--space-3);">
                                <div style="font-size: var(--text-xs); color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: var(--space-1);">Gambling Txns</div>
                                <div style="font-weight: 700; font-size: var(--text-base); color: @(internal_.GamblingTransactions > 0 ? "var(--danger-600)" : "var(--gray-900)");">@internal_.GamblingTransactions</div>
                            </div>
                        }
                    </div>
                }

            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            <span class="material-symbols-outlined" style="font-size: 20px; vertical-align: middle; margin-right: var(--space-2);">account_balance_wallet</span>
            Other Bank Statements
        </h3>
        @if (IsEditable)
        {
            <button class="btn btn-sm btn-primary" @onclick="OnUpload">
                <span class="material-symbols-outlined" style="font-size: 16px;">upload</span>
                Upload Statement
            </button>
        }
    </div>
    <div class="card-body" style="padding: 0;">
        @{
            var externals = Statements.Where(s => !s.IsInternal).ToList();
        }
        @if (!externals.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <span class="material-symbols-outlined">library_add</span>
                </div>
                <div class="empty-state-title">No external statements</div>
                <div class="empty-state-text">External statements from other banks strengthen the credit analysis. Adding verified external statements increases confidence.</div>
            </div>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Bank / Account</th>
                        <th>Period</th>
                        <th>Trust</th>
                        <th>Verification</th>
                        <th>Analysis</th>
                        <th>Txns</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var stmt in externals)
                    {
                        <tr>
                            <td>
                                <div style="font-weight: 500;">@stmt.BankName</div>
                                <div style="font-size: var(--text-xs); color: var(--gray-500);">@stmt.AccountNumber</div>
                            </td>
                            <td>
                                <div>@stmt.PeriodStart.ToString("MMM yyyy") – @stmt.PeriodEnd.ToString("MMM yyyy")</div>
                                <div style="font-size: var(--text-xs); color: var(--gray-500);">@stmt.MonthsCovered months</div>
                            </td>
                            <td>@TrustBadge(stmt.TrustWeight, stmt.IsInternal)</td>
                            <td>
                                @VerificationBadge(stmt.VerificationStatus)
                                @if (stmt.VerificationStatus == "Rejected" && !string.IsNullOrEmpty(stmt.VerificationNotes))
                                {
                                    <div style="font-size: var(--text-xs); color: var(--danger-600); margin-top: var(--space-1); max-width: 160px;">
                                        @stmt.VerificationNotes
                                    </div>
                                }
                            </td>
                            <td>@AnalysisBadge(stmt.AnalysisStatus)</td>
                            <td>@stmt.TransactionCount</td>
                            <td>
                                <div style="display: flex; gap: var(--space-2);">
                                    @if (IsEditable && stmt.VerificationStatus != "Rejected")
                                    {
                                        <button class="btn btn-sm btn-primary" @onclick="() => OnEnterTransactions.InvokeAsync(stmt.Id)"
                                                title="@(stmt.TransactionCount == 0 ? "Enter transactions" : "Add more transactions")">
                                            <span class="material-symbols-outlined" style="font-size: 16px;">edit_note</span>
                                            @(stmt.TransactionCount == 0 ? "Enter Txns" : "Add Txns")
                                        </button>
                                    }
                                    @if (stmt.TransactionCount > 0)
                                    {
                                        <button class="btn btn-sm btn-outline" @onclick="() => OnViewTransactions.InvokeAsync(stmt.Id)" title="View transactions">
                                            <span class="material-symbols-outlined" style="font-size: 16px;">list</span>
                                        </button>
                                    }
                                    @if (CanVerifyStatements && stmt.VerificationStatus == "Pending")
                                    {
                                        <button class="btn btn-sm btn-success" @onclick="() => OnVerify.InvokeAsync(stmt.Id)"
                                                title="@(stmt.TransactionCount == 0 ? "Cannot verify — no transactions entered" : "Verify statement")"
                                                disabled="@(stmt.TransactionCount == 0)">
                                            <span class="material-symbols-outlined" style="font-size: 16px;">check</span>
                                        </button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => OnReject.InvokeAsync(stmt.Id)" title="Reject">
                                            <span class="material-symbols-outlined" style="font-size: 16px;">close</span>
                                        </button>
                                    }
                                    @if (CanAnalyzeStatements && stmt.AnalysisStatus == "Pending" && stmt.VerificationStatus != "Rejected")
                                    {
                                        <button class="btn btn-sm btn-outline" @onclick="() => OnAnalyze.InvokeAsync(stmt.Id)"
                                                title="@(stmt.TransactionCount == 0 ? "Cannot analyze — no transactions entered" : "Run cashflow analysis")"
                                                disabled="@(stmt.TransactionCount == 0)">
                                            <span class="material-symbols-outlined" style="font-size: 16px;">analytics</span>
                                        </button>
                                    }
                                    @if (IsEditable)
                                    {
                                        <button class="btn btn-sm btn-ghost" style="color: var(--danger-500);"
                                                @onclick="() => OnDelete.InvokeAsync(stmt.Id)"
                                                title="Delete this statement">
                                            <span class="material-symbols-outlined" style="font-size: 16px;">delete</span>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    [Parameter] public List<BankStatementInfo> Statements { get; set; } = [];
    [Parameter] public bool IsEditable { get; set; }
    [Parameter] public bool CanVerifyStatements { get; set; }
    [Parameter] public bool CanAnalyzeStatements { get; set; }
    private bool isRefetching;

    [Parameter] public EventCallback OnUpload { get; set; }
    [Parameter] public EventCallback OnRefetch { get; set; }
    [Parameter] public EventCallback<Guid> OnEnterTransactions { get; set; }
    [Parameter] public EventCallback<Guid> OnVerify { get; set; }
    [Parameter] public EventCallback<Guid> OnReject { get; set; }
    [Parameter] public EventCallback<Guid> OnAnalyze { get; set; }
    [Parameter] public EventCallback<Guid> OnViewTransactions { get; set; }
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }

    private async Task HandleRefetch()
    {
        if (isRefetching) return;
        isRefetching = true;
        try { await OnRefetch.InvokeAsync(); }
        finally { isRefetching = false; }
    }

    private static string FormatAmount(decimal amount) =>
        amount >= 1_000_000_000 ? $"{amount / 1_000_000_000:N2}B"
        : amount >= 1_000_000 ? $"{amount / 1_000_000:N2}M"
        : amount >= 1_000 ? $"{amount / 1_000:N2}K"
        : amount.ToString("N0");

    private RenderFragment TrustBadge(decimal weight, bool isInternal) => __builder =>
    {
        if (isInternal)
        {
            __builder.OpenElement(0, "span");
            __builder.AddAttribute(1, "class", "badge badge-success");
            __builder.AddAttribute(2, "title", "Internal statement — highest trust");
            __builder.AddContent(3, "Internal 100%");
            __builder.CloseElement();
        }
        else if (weight >= 0.85m)
        {
            __builder.OpenElement(0, "span");
            __builder.AddAttribute(1, "class", "badge badge-primary");
            __builder.AddAttribute(2, "title", "Verified external statement");
            __builder.AddContent(3, $"Verified {weight:P0}");
            __builder.CloseElement();
        }
        else
        {
            __builder.OpenElement(0, "span");
            __builder.AddAttribute(1, "class", "badge badge-warning");
            __builder.AddAttribute(2, "title", "Unverified external statement — pending review");
            __builder.AddContent(3, $"Unverified {weight:P0}");
            __builder.CloseElement();
        }
    };

    private RenderFragment VerificationBadge(string status) => __builder =>
    {
        var (cls, label) = status switch
        {
            "Verified" => ("badge-success", "Verified"),
            "Rejected" => ("badge-danger", "Rejected"),
            _ => ("badge-warning", "Pending Review")
        };
        __builder.OpenElement(0, "span");
        __builder.AddAttribute(1, "class", $"badge {cls}");
        __builder.AddContent(2, label);
        __builder.CloseElement();
    };

    private RenderFragment AnalysisBadge(string status) => __builder =>
    {
        var (cls, label) = status switch
        {
            "Completed" => ("badge-success", "✓ Analyzed"),
            "Processing" => ("badge-primary", "Processing…"),
            "Failed" => ("badge-danger", "Failed"),
            _ => ("badge-gray", "Pending")
        };
        __builder.OpenElement(0, "span");
        __builder.AddAttribute(1, "class", $"badge {cls}");
        __builder.AddContent(2, label);
        __builder.CloseElement();
    };
}
