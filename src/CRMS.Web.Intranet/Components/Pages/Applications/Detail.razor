    // Offer letter workflow
    private bool ShowIssueOfferLetterButton =>
        application?.Status == AppStatus.Approved &&
        (AuthService.CurrentUser?.HasAnyRole("Operations", "LoanOfficer", "SystemAdmin") ?? false);

    private bool ShowRecordAcceptanceButton =>
        application?.Status == AppStatus.OfferGenerated &&
        (AuthService.CurrentUser?.HasAnyRole("Operations") ?? false);

