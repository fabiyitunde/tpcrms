@page "/applications/{Id:guid}"
@using CRMS.Web.Intranet.Components.Pages.Applications.Modals
@inject ApplicationService AppService
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@(application?.ApplicationNumber ?? "Application") - CRMS</PageTitle>

@if (isLoading)
{
    <div class="card p-6 text-center">
        <div class="spinner" style="margin: 0 auto;"></div>
        <p class="text-muted mt-4">Loading application...</p>
    </div>
}
else if (application == null)
{
    <div class="card">
        <div class="empty-state">
            <div class="empty-state-icon">
                <span class="material-symbols-outlined">error</span>
            </div>
            <div class="empty-state-title">Application not found</div>
            <div class="empty-state-text">The application you're looking for doesn't exist or you don't have permission to view it.</div>
            <a href="/applications" class="btn btn-primary">Back to Applications</a>
        </div>
    </div>
}
else
{
    <div class="page-header">
        <div style="display: flex; align-items: center; gap: var(--space-4);">
            <button class="btn btn-ghost" @onclick="GoBack">
                <span class="material-symbols-outlined">arrow_back</span>
            </button>
            <div>
                <div style="display: flex; align-items: center; gap: var(--space-3);">
                    <h1 class="page-title">@application.ApplicationNumber</h1>
                    <span class="badge @GetStatusBadgeClass(application.Status)" style="font-size: var(--text-sm);">
                        @FormatStatus(application.Status)
                    </span>
                </div>
                <p class="page-subtitle">@application.Customer.CompanyName</p>
            </div>
        </div>
        <div style="display: flex; gap: var(--space-3);">
            @if (ShowSubmitForReviewButton)
            {
                <button class="btn btn-primary" @onclick="ShowSubmitForReviewModal" disabled="@isSubmittingForReview">
                    @if (isSubmittingForReview)
                    {
                        <span class="spinner"></span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined" style="font-size: 18px;">send</span>
                    }
                    Submit for Review
                </button>
            }
            @if (CanGeneratePack)
            {
                <button class="btn btn-outline" @onclick="GenerateLoanPack" disabled="@isGeneratingPack">
                    @if (isGeneratingPack)
                    {
                        <span class="spinner"></span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined" style="font-size: 18px;">picture_as_pdf</span>
                    }
                    Loan Pack
                </button>
            }
            @if (CanGenerateOfferLetter)
            {
                <button class="btn btn-primary" @onclick="GenerateOfferLetter" disabled="@isGeneratingOfferLetter">
                    @if (isGeneratingOfferLetter)
                    {
                        <span class="spinner"></span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined" style="font-size: 18px;">mail</span>
                    }
                    Offer Letter
                </button>
            }
            @if (CanRerunCreditChecks)
            {
                <button class="btn btn-secondary" @onclick="() => RequestBureauCheck()" disabled="@isRunningBureauChecks">
                    @if (isRunningBureauChecks)
                    {
                        <span class="spinner"></span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined" style="font-size: 18px;">refresh</span>
                    }
                    Re-run Credit Checks
                </button>
            }
            @if (ShowApproveButton)
            {
                <button class="btn btn-success" @onclick="HandleApproveClick" disabled="@isCheckingGate">
                    @if (isCheckingGate)
                    {
                        <span class="material-symbols-outlined spin" style="font-size: 18px;">progress_activity</span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined" style="font-size: 18px;">check</span>
                    }
                    Approve
                </button>
            }
            @if (ShowReturnButton)
            {
                <button class="btn btn-secondary" @onclick="() => ShowActionModal(ActionType.Return)">
                    <span class="material-symbols-outlined" style="font-size: 18px;">undo</span>
                    Return
                </button>
            }
            @if (ShowRejectButton)
            {
                <button class="btn btn-danger" @onclick="() => ShowActionModal(ActionType.Reject)">
                    <span class="material-symbols-outlined" style="font-size: 18px;">close</span>
                    Reject
                </button>
            }
            @if (ShowIssueOfferLetterButton)
            {
                <button class="btn btn-primary" @onclick="IssueOfferLetter" disabled="@isIssuingOfferLetter">
                    @if (isIssuingOfferLetter)
                    {
                        <span class="spinner"></span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined" style="font-size: 18px;">send</span>
                    }
                    Issue Offer Letter
                </button>
            }
            @if (ShowRecordAcceptanceButton)
            {
                <button class="btn btn-success" @onclick="ShowRecordAcceptanceModalFn">
                    <span class="material-symbols-outlined" style="font-size: 18px;">how_to_reg</span>
                    Record Customer Acceptance
                </button>
            }
            @if (ShowDisburseButton)
            {
                <button class="btn btn-primary" @onclick="ShowDisburseModalFn">
                    <span class="material-symbols-outlined" style="font-size: 18px;">payments</span>
                    Disburse Loan
                </button>
            }
        </div>
    </div>

    <div class="card mb-6">
        <div class="card-body" style="padding: var(--space-4) var(--space-6);">
            <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: var(--space-6);">
                <div>
                    <div style="font-size: var(--text-xs); color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.05em;">Product</div>
                    <div style="font-weight: 500; margin-top: var(--space-1);">@application.Loan.ProductName</div>
                </div>
                <div>
                    <div style="font-size: var(--text-xs); color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.05em;">Requested Amount</div>
                    <div style="font-weight: 600; margin-top: var(--space-1); color: var(--primary-600);">@FormatCurrency(application.Loan.RequestedAmount)</div>
                </div>
                <div>
                    <div style="font-size: var(--text-xs); color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.05em;">Tenor</div>
                    <div style="font-weight: 500; margin-top: var(--space-1);">@application.Loan.TenorMonths months</div>
                </div>
                <div>
                    <div style="font-size: var(--text-xs); color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.05em;">Interest Rate</div>
                    <div style="font-weight: 500; margin-top: var(--space-1);">@application.Loan.InterestRate% @application.Loan.InterestRateType</div>
                </div>
                <div>
                    <div style="font-size: var(--text-xs); color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.05em;">Created</div>
                    <div style="font-weight: 500; margin-top: var(--space-1);">@application.CreatedAt.ToString("MMM dd, yyyy")</div>
                </div>
            </div>
        </div>
    </div>

    @if (approvalOverrides.Count > 0)
    {
        <div style="margin-bottom: var(--space-4);">
            @foreach (var override_ in approvalOverrides)
            {
                <div style="border-radius: var(--radius-md); padding: var(--space-3) var(--space-4); margin-bottom: var(--space-2);
                            border-left: 4px solid @(override_.IsResolved ? "var(--gray-300)" : "var(--warning-500)");
                            background: @(override_.IsResolved ? "var(--gray-50)" : "var(--warning-50)");
                            opacity: @(override_.IsResolved ? "0.8" : "1");">
                    <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: var(--space-3);">
                        <div style="display: flex; align-items: flex-start; gap: var(--space-2);">
                            <span class="material-symbols-outlined" style="font-size: 18px; color: @(override_.IsResolved ? "var(--gray-400)" : "var(--warning-600)"); margin-top: 2px;">warning</span>
                            <div>
                                <div style="font-size: var(--text-sm); font-weight: 600; color: @(override_.IsResolved ? "var(--gray-500)" : "var(--warning-800)");">
                                    @(override_.IsResolved ? "[Resolved]" : "") Override at @override_.Stage stage by @override_.ActorName
                                </div>
                                <div style="font-size: var(--text-sm); color: @(override_.IsResolved ? "var(--gray-400)" : "var(--warning-700)"); margin-top: var(--space-1);">
                                    @override_.NoteText
                                </div>
                                <div style="font-size: var(--text-xs); color: var(--gray-400); margin-top: var(--space-1);">
                                    @override_.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                    @if (override_.IsResolved && override_.ResolvedAt.HasValue)
                                    {
                                        <span> — Resolved @override_.ResolvedAt.Value.ToString("MMM dd, yyyy") by @override_.ResolvedByName</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="tabs">
        <div class="tab @(activeTab == "overview" ? "active" : "")" @onclick='() => activeTab = "overview"'>Overview</div>
        <div class="tab @(activeTab == "parties" ? "active" : "")" @onclick='() => activeTab = "parties"'>Directors & Signatories</div>
        <div class="tab @(activeTab == "documents" ? "active" : "")" @onclick='() => activeTab = "documents"'>Documents</div>
        <div class="tab @(activeTab == "financials" ? "active" : "")" @onclick='() => activeTab = "financials"'>Financial Analysis</div>
        <div class="tab @(activeTab == "statements" ? "active" : "")" @onclick='() => activeTab = "statements"'>Bank Statements</div>
        <div class="tab @(activeTab == "bureau" ? "active" : "")" @onclick='() => activeTab = "bureau"'>Credit Bureau</div>
        <div class="tab @(activeTab == "collateral" ? "active" : "")" @onclick='() => activeTab = "collateral"'>Collateral</div>
        <div class="tab @(activeTab == "guarantors" ? "active" : "")" @onclick='() => activeTab = "guarantors"'>Guarantors</div>
        <div class="tab @(activeTab == "advisory" ? "active" : "")" @onclick='() => activeTab = "advisory"'>AI Advisory</div>
        <div class="tab @(activeTab == "workflow" ? "active" : "")" @onclick='() => activeTab = "workflow"'>Workflow</div>
        <div class="tab @(activeTab == "committee" ? "active" : "")" @onclick='() => activeTab = "committee"'>Committee</div>
        <div class="tab @(activeTab == "comments" ? "active" : "")" @onclick='() => activeTab = "comments"'>Comments</div>
        @if (CanGenerateOfferLetter)
        {
            <div class="tab @(activeTab == "offerletters" ? "active" : "")" @onclick='() => activeTab = "offerletters"'>
                Offer Letters
                @if (offerLetters.Count > 0)
                {
                    <span class="badge badge-primary" style="margin-left: var(--space-2); font-size: var(--text-xs);">@offerLetters.Count</span>
                }
            </div>
        }
        @if (application?.Status is AppStatus.OfferGenerated or AppStatus.OfferAccepted or AppStatus.Disbursed)
        {
            <div class="tab @(activeTab == "checklist" ? "active" : "")" @onclick='() => activeTab = "checklist"'>
                <span class="material-symbols-outlined" style="font-size: 16px; margin-right: 4px;">checklist</span>
                Disbursement Checklist
            </div>
        }
    </div>

    @if (inlineActionError != null)
    {
        <div class="alert alert-danger" id="inline-action-error" style="margin-bottom: var(--space-4); display: flex; align-items: center; gap: var(--space-2);">
            <span class="material-symbols-outlined" style="font-size: 18px;">error</span>
            @inlineActionError
            <button type="button" style="margin-left: auto; background: none; border: none; cursor: pointer;" @onclick="() => inlineActionError = null">
                <span class="material-symbols-outlined" style="font-size: 16px;">close</span>
            </button>
        </div>
    }

    @if (application.Status == AppStatus.HOReview && application.Committee?.Decision == "Deferred")
    {
        <div style="margin: 0 0 var(--space-4) 0; padding: var(--space-3) var(--space-4); background: var(--warning-50); border: 1px solid var(--warning-200); border-radius: var(--radius-md); display: flex; gap: var(--space-3); align-items: flex-start;">
            <span class="material-symbols-outlined" style="color: var(--warning-600); font-size: 20px; flex-shrink: 0; margin-top: 2px;">undo</span>
            <div>
                <div style="font-weight: 600; color: var(--warning-800); font-size: var(--text-sm);">
                    Returned from Committee — Deferred
                </div>
                <div style="color: var(--warning-700); font-size: var(--text-sm); margin-top: var(--space-1);">
                    The committee deferred this application on @application.Committee.DecisionDate?.ToString("MMM dd, yyyy").
                    @if (!string.IsNullOrWhiteSpace(application.Committee.DecisionComments))
                    {
                        <span>Rationale: <strong>@application.Committee.DecisionComments</strong>.</span>
                    }
                    Review the committee's concerns and take action using the buttons above.
                </div>
            </div>
        </div>
    }

    @switch (activeTab)
    {
        case "overview":
            <OverviewTab Application="application" />
            break;
        case "parties":
            <PartiesTab Directors="application.Directors" Signatories="application.Signatories"
                IsEditable="IsApplicationEditable"
                OnRequestBureauCheck="RequestBureauCheck"
                OnFillPartyInfo="ShowFillPartyInfoModal"
                OnViewPartyBureauReport="ShowBureauReportModal" />
            break;
        case "statements":
            <StatementsTab
                Statements="application.BankStatements"
                IsEditable="IsApplicationEditable"
                CanVerifyStatements="CanVerifyStatements"
                CanAnalyzeStatements="CanAnalyzeStatements"
                OnUpload="ShowUploadStatementModal"
                OnRefetch="RefetchInternalStatement"
                OnEnterTransactions="ShowManageStatementTransactionsModal"
                OnVerify="VerifyStatement"
                OnReject="ShowRejectStatementModal"
                OnAnalyze="AnalyzeStatement"
                OnViewTransactions="ShowViewStatementTransactionsModal"
                OnDelete="ShowDeleteStatementModal" />
            break;
        case "documents":
            <DocumentsTab
                Documents="application.Documents"
                IsEditable="IsApplicationEditable"
                CanVerifyDocuments="CanVerifyDocuments"
                OnUploadDocument="ShowUploadDocumentModal"
                OnVerifyDocument="VerifyDocument"
                OnRejectDocument="ShowRejectDocumentModal"
                OnDeleteDocument="ShowDeleteDocumentModal" />
            break;
        case "financials":
            <FinancialsTab
                Analysis="application.FinancialAnalysis"
                Statements="application.FinancialStatements"
                IncorporationDate="application.Customer.IncorporationDate"
                IsEditable="IsApplicationEditable"
                CanVerifyFinancials="CanVerifyFinancials"
                OnEnterFinancials="ShowFinancialStatementModal"
                OnUploadExcel="ShowExcelUploadModal"
                OnViewStatement="ViewFinancialStatement"
                OnEditStatement="EditFinancialStatement"
                OnDeleteStatement="DeleteFinancialStatement"
                OnVerifyStatement="VerifyFinancialStatement"
                OnRejectStatement="ShowRejectFinancialStatementModal"
                OnDeleteAll="DeleteAllFinancialStatements" />
            break;
        case "bureau":
            <BureauTab Reports="application.BureauReports" OnViewReport="ShowBureauReportModal" />
            break;
        case "collateral":
            <CollateralTab
                Collaterals="application.Collaterals"
                IsEditable="IsApplicationEditable"
                CanManageValuation="CanManageValuation"
                CanClearLegal="CanClearCollateralLegal"
                OnAddCollateral="ShowAddCollateralModal"
                OnViewCollateral="ViewCollateral"
                OnEditCollateral="EditCollateral"
                OnDeleteCollateral="DeleteCollateral"
                OnSetValuation="ShowSetValuationModal"
                OnApproveCollateral="ShowApproveCollateralModal"
                OnRecordLegalClearance="ShowLegalClearanceModal"
                OnUploadDocument="ShowUploadCollateralDocModal" />
            break;
        case "guarantors":
            <GuarantorsTab 
                Guarantors="application.Guarantors" 
                IsEditable="IsApplicationEditable"
                CanManageGuarantors="CanManageGuarantors"
                OnAddGuarantor="ShowAddGuarantorModal"
                OnViewGuarantor="ViewGuarantor"
                OnEditGuarantor="EditGuarantor"
                OnDeleteGuarantor="DeleteGuarantor"
                OnApproveGuarantor="ShowApproveGuarantorModal"
                OnRejectGuarantor="ShowRejectGuarantorModal" />
            break;
        case "advisory":
            <AdvisoryTab Advisory="application.Advisory" OnGenerateAdvisory="GenerateAdvisory" IsGenerating="isGeneratingAdvisory" CanGenerate="CanGenerateAdvisory" />
            break;
        case "workflow":
            <WorkflowTab History="application.WorkflowHistory" CurrentStatus="application.Status" />
            break;
        case "committee":
            <CommitteeTab Committee="application.Committee"
                             CurrentUserId="AuthService.CurrentUser?.Id"
                             CanSetupCommittee="@CanSetupCommitteeReview"
                             CanManageCommittee="@CanManageCommitteeReview"
                             CanConfirmDecision="@CanConfirmCommitteeDecision"
                             AvailableMemberUsers="committeeUsers"
                             RequestedAmount="application.Loan.RequestedAmount"
                             RequestedInterestRate="application.Loan.InterestRate"
                             RequestedTenorMonths="application.Loan.TenorMonths"
                             OnCastVote="CastVote"
                             OnSetupCommittee="ShowSetupCommitteeModal"
                             OnRemoveMember="RemoveCommitteeMember"
                             OnAddMember="AddCommitteeMember"
                             OnStartVoting="StartCommitteeVoting"
                             OnConfirmDecision="ConfirmCommitteeDecision" />
            break;
        case "comments":
            <CommentsTab Comments="application.Comments" OnAddComment="AddComment" IsSubmitting="isAddingComment" SubmitError="commentError" />
            break;
        case "checklist":
            <OfferAcceptanceTab ApplicationId="application.Id" ApplicationStatus="application.Status" />
            break;
        case "offerletters":
            <div class="card">
                <div class="card-header" style="display: flex; align-items: center; justify-content: space-between;">
                    <h3 class="card-title">Offer Letters</h3>
                    <button class="btn btn-primary btn-sm" @onclick="GenerateOfferLetter" disabled="@isGeneratingOfferLetter">
                        @if (isGeneratingOfferLetter)
                        {
                            <span class="spinner"></span>
                        }
                        else
                        {
                            <span class="material-symbols-outlined" style="font-size: 16px;">add</span>
                        }
                        Generate New
                    </button>
                </div>
                <div class="card-body">
                    @if (!offerLetters.Any())
                    {
                        <div class="empty-state" style="padding: var(--space-8) 0;">
                            <div class="empty-state-icon">
                                <span class="material-symbols-outlined">mail</span>
                            </div>
                            <div class="empty-state-title">No offer letters generated yet</div>
                            <div class="empty-state-text">Click "Generate New" to create the first offer letter for this application.</div>
                        </div>
                    }
                    else
                    {
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Version</th>
                                    <th>File Name</th>
                                    <th>Size</th>
                                    <th>Status</th>
                                    <th>Generated By</th>
                                    <th>Generated At</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var letter in offerLetters)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge badge-secondary">v@(letter.Version)</span>
                                        </td>
                                        <td style="font-size: var(--text-sm);">@letter.FileName</td>
                                        <td style="font-size: var(--text-sm); color: var(--gray-500);">@FormatFileSize(letter.FileSizeBytes)</td>
                                        <td>
                                            <span class="badge @(letter.Status == "Generated" ? "badge-success" : letter.Status == "Superseded" ? "badge-secondary" : "badge-warning")">
                                                @letter.Status
                                            </span>
                                        </td>
                                        <td style="font-size: var(--text-sm);">@letter.GeneratedByUserName</td>
                                        <td style="font-size: var(--text-sm); color: var(--gray-500);">@letter.GeneratedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                                        <td>
                                            <button class="btn btn-ghost btn-sm" title="Download"
                                                @onclick="() => DownloadOfferLetter(letter.Id)"
                                                disabled="@(isDownloadingOfferLetter && downloadingOfferLetterId == letter.Id)">
                                                @if (isDownloadingOfferLetter && downloadingOfferLetterId == letter.Id)
                                                {
                                                    <span class="spinner" style="width: 14px; height: 14px;"></span>
                                                }
                                                else
                                                {
                                                    <span class="material-symbols-outlined" style="font-size: 18px;">download</span>
                                                }
                                            </button>
                                            <button class="btn btn-ghost btn-sm" title="Download Amortisation Schedule"
                                                @onclick="() => DownloadSchedule(letter.Id)"
                                                disabled="@(isDownloadingSchedule && downloadingScheduleId == letter.Id)">
                                                @if (isDownloadingSchedule && downloadingScheduleId == letter.Id)
                                                {
                                                    <span class="spinner" style="width: 14px; height: 14px;"></span>
                                                }
                                                else
                                                {
                                                    <span class="material-symbols-outlined" style="font-size: 18px;">table_chart</span>
                                                }
                                            </button>
                                            <button class="btn btn-ghost btn-sm" title="Download Key Facts Statement"
                                                @onclick="() => DownloadKfs(letter.Id)"
                                                disabled="@(isDownloadingKfs && downloadingKfsId == letter.Id)">
                                                @if (isDownloadingKfs && downloadingKfsId == letter.Id)
                                                {
                                                    <span class="spinner" style="width: 14px; height: 14px;"></span>
                                                }
                                                else
                                                {
                                                    <span class="material-symbols-outlined" style="font-size: 18px;">fact_check</span>
                                                }
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
            break;
    }
}

<ApprovalGateModal IsVisible="showApprovalGateModal"
                   GateResult="approvalGateResult"
                   OnCancel="CloseApprovalGateModal"
                   OnProceed="HandleGateProceed" />

@if (showActionModal)
{
    <div class="modal-backdrop show" @onclick="CloseActionModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h3 class="modal-title">@GetActionTitle()</h3>
                <button class="modal-close" @onclick="CloseActionModal">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Comments @(currentAction == ActionType.Approve ? "(Optional)" : "(Required)")</label>
                    <textarea class="form-control" rows="4" @bind="actionComments" placeholder="Enter your comments..."></textarea>
                </div>
                @if (actionError != null)
                {
                    <div class="alert alert-danger mt-3">@actionError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseActionModal">Cancel</button>
                <button class="btn @GetActionButtonClass()" @onclick="ExecuteAction" disabled="@isExecutingAction">
                    @if (isExecutingAction)
                    {
                        <span class="spinner"></span>
                    }
                    @GetActionButtonText()
                </button>
            </div>
        </div>
    </div>
}

@if (showCollateralModal)
{
    <AddCollateralModal 
        ApplicationId="Id" 
        OnClose="CloseCollateralModal" 
        OnSuccess="OnCollateralAdded" />
}

@if (showViewCollateralModal && viewingCollateralId.HasValue)
{
    <ViewCollateralModal 
        CollateralId="viewingCollateralId.Value"
        CanDelete="IsApplicationEditable || CanManageValuation"
        OnClose="CloseViewCollateralModal"
        OnDocumentDeleted="OnCollateralDocumentDeleted" />
}

@if (showEditCollateralModal && editingCollateralId.HasValue)
{
    <EditCollateralModal
        CollateralId="editingCollateralId.Value"
        OnClose="CloseEditCollateralModal"
        OnSuccess="OnCollateralUpdated" />
}

@if (showSetValuationModal && valuatingCollateralId.HasValue)
{
    <SetCollateralValuationModal
        CollateralId="valuatingCollateralId.Value"
        OnClose="CloseSetValuationModal"
        OnSuccess="OnCollateralValuated" />
}

@if (showLegalClearanceModal && legalClearanceCollateralId.HasValue)
{
    <RecordLegalClearanceModal CollateralId="legalClearanceCollateralId.Value"
        OnClose="CloseLegalClearanceModal"
        OnSuccess="HandleLegalClearanceSuccess" />
}

@if (showApproveCollateralModal && approvingCollateralId.HasValue)
{
    var collateralToApprove = application?.Collaterals.FirstOrDefault(c => c.Id == approvingCollateralId.Value);
    <div class="modal-backdrop show" @onclick="CloseApproveCollateralModal">
        <div class="modal" style="max-width: 450px;" @onclick:stopPropagation>
            <div class="modal-header">
                <h3 class="modal-title">
