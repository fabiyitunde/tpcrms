    private bool isIssuingOfferLetter;

    private async Task IssueOfferLetter()
    {
        if (!EnsureAuthenticated(out var userId)) return;
        isIssuingOfferLetter = true;
        inlineActionError = null;
        StateHasChanged();
        try
        {
            var userName = AuthService.CurrentUser?.FullName ?? "System";
            var userRole = AuthService.CurrentUser?.PrimaryRole ?? "Operations";

            // Generate the PDF first if not already generated
            if (!offerLetters.Any(l => l.Status == "Generated"))
            {
                var genResult = await AppService.GenerateOfferLetterAsync(Id, userId, userName);
                if (!genResult.Success)
                {
                    inlineActionError = genResult.Error ?? "Failed to generate offer letter PDF.";
                    await JS.InvokeVoidAsync("scrollToElement", "inline-action-error");
                    return;
                }
                offerLetters = await AppService.GetOfferLettersByApplicationAsync(Id);
                // Auto-download
                if (genResult.Data != null)
                {
                    var bytes = await AppService.DownloadGeneratedFileAsync(genResult.Data.StoragePath ?? string.Empty);
                    if (bytes != null)
                        await JS.InvokeVoidAsync("downloadFileFromBytes", genResult.Data.FileName, "application/pdf", bytes);
                }
            }

            // Transition status to OfferGenerated
            var result = await AppService.IssueOfferLetterAsync(Id, userId, userRole, null);
            // Always reload so UI reflects true DB state (avoids stale Approved status after partial failure)
            await LoadApplication();
            if (!result.Success)
            {
                inlineActionError = result.Error ?? "Failed to update status.";
                await JS.InvokeVoidAsync("scrollToElement", "inline-action-error");
            }
        }
        finally
        {
            isIssuingOfferLetter = false;
        }
    }

