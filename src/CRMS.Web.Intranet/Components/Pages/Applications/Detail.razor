@code {
    [Parameter] public Guid Id { get; set; }

    private LoanApplicationDetail? application;
    private string activeTab = "overview";
    private bool isLoading = true;
    private bool isGeneratingPack;

    private bool showActionModal;
    private ActionType currentAction;
    private string actionComments = string.Empty;
    private bool isExecutingAction;
    private string? actionError;

    // Approval gate
    private bool isCheckingGate;
    private bool showApprovalGateModal;
    private ApprovalGateResultModel? approvalGateResult;
    private List<ApprovalOverrideInfo> approvalOverrides = [];
    private bool showSetupCommitteeModal;
    private List<UserSummary> committeeUsers = [];

    // Data entry modals
    private bool showCollateralModal;
    private bool showViewCollateralModal;
    private bool showEditCollateralModal;
    private bool showDeleteCollateralModal;
    private Guid? viewingCollateralId;
    private Guid? editingCollateralId;
    private Guid? deletingCollateralId;

    private bool showGuarantorModal;
    private bool showViewGuarantorModal;
    private bool showEditGuarantorModal;
    private bool showDeleteGuarantorModal;
    private Guid? viewingGuarantorId;
    private Guid? editingGuarantorId;
    private Guid? deletingGuarantorId;

    private string? deleteErrorMessage;

    private bool showDocumentModal;
    private bool showFinancialStatementModal;
    private bool showExcelUploadModal;

    // Submit for review
    private bool showSubmitReviewModal;
    private bool isSubmittingForReview;
    private string submitComments = string.Empty;
    private List<string> validationErrors = [];
    private string? submitError;

    private enum ActionType { Approve, Return, Reject }

    protected override async Task OnInitializedAsync()
    {
        await LoadApplication();
    }

    private async Task LoadApplication()
    {
        isLoading = true;
        inlineActionError = null;
        application = await AppService.GetApplicationDetailAsync(Id);
        
        // Mock data only for the seeded admin demo account
        if (application == null && AuthService.CurrentUser?.Username == "admin")
        {
            application = GenerateMockApplication();
        }
        else if (application != null)
        {
            // Fetch real bureau reports from database
            application.BureauReports = await AppService.GetBureauReportsAsync(Id);

            // Cross-reference bureau reports into directors/signatories so PartiesTab can show status + view button
            foreach (var party in application.Directors.Concat(application.Signatories))
            {
                var report = application.BureauReports.FirstOrDefault(r => r.PartyId == party.Id && r.Status == "Completed");
                if (report != null)
                {
                    party.HasBureauReport = true;
                    party.BureauStatus = report.Rating;
                    party.BureauReportId = report.Id;
                }
            }
            // Fetch bank statements
            application.BankStatements = await AppService.GetBankStatementsAsync(Id);
            // Fetch approval overrides (warning banners)
            approvalOverrides = await AppService.GetApprovalOverridesAsync(Id);
            // Fetch offer letters (only relevant once application is Approved or Disbursed)
            if (application.Status is AppStatus.Approved or AppStatus.OfferGenerated or AppStatus.OfferAccepted or AppStatus.Disbursed)
                offerLetters = await AppService.GetOfferLettersByApplicationAsync(Id);
            // Fetch committee member users when in committee stage
            if (application.Status == AppStatus.CommitteeCirculation)
                committeeUsers = await AppService.GetCommitteeMemberUsersAsync();
        }
        
        isLoading = false;
        StateHasChanged();
    }

    private void GoBack() => Navigation.NavigateTo("/applications");

    private bool CanGeneratePack =>
        application?.Status is not (null or AppStatus.Draft or AppStatus.Rejected or AppStatus.CommitteeRejected or AppStatus.Cancelled or AppStatus.Closed) &&
        (AuthService.CurrentUser?.HasAnyRole("LoanOfficer", "CreditOfficer", "HOReviewer", "BranchApprover", "FinalApprover", "Operations", "SystemAdmin") ?? false ||
         application?.Committee?.Members.Any(m => m.UserId == (AuthService.CurrentUser?.Id ?? Guid.Empty)) == true);
    private bool CanGenerateOfferLetter => application?.Status is AppStatus.Approved or AppStatus.OfferGenerated or AppStatus.OfferAccepted or AppStatus.Disbursed;

    // Application is editable only in Draft status
    private bool IsApplicationEditable => application?.Status == AppStatus.Draft;

    // Advisory is a Credit Officer tool — only available at CreditAnalysis stage, and only after all bureau checks have completed
    private bool CanGenerateAdvisory =>
        application?.Status == AppStatus.CreditAnalysis &&
        (AuthService.CurrentUser?.HasRole("CreditOfficer") ?? false) &&
        (application.BureauReports.Any() && application.BureauReports.All(r => r.Status == "Completed"));

    // Bank statement verification (authenticity check): BranchApprover at BranchReview
    private bool CanVerifyStatements => application?.Status switch
    {
        AppStatus.BranchReview => AuthService.CurrentUser?.HasRole("BranchApprover") ?? false,
        AppStatus.HOReview     => AuthService.CurrentUser?.HasRole("HOReviewer") ?? false,
        _ => AuthService.CurrentUser?.HasRole("SystemAdmin") ?? false
    };

    // Cashflow analysis: CreditOfficer at CreditAnalysis (operates on verified statements)
    private bool CanAnalyzeStatements => application?.Status switch
    {
        AppStatus.CreditAnalysis => AuthService.CurrentUser?.HasRole("CreditOfficer") ?? false,
        _ => AuthService.CurrentUser?.HasRole("SystemAdmin") ?? false
    };

    // Document verification: stage-gated — each actor verifies documents at their own review stage only
    private bool CanVerifyDocuments => application?.Status switch
    {
        AppStatus.BranchReview   => AuthService.CurrentUser?.HasRole("BranchApprover") ?? false,
        AppStatus.CreditAnalysis => AuthService.CurrentUser?.HasRole("CreditOfficer") ?? false,
        AppStatus.HOReview       => AuthService.CurrentUser?.HasRole("HOReviewer") ?? false,
        _ => AuthService.CurrentUser?.HasRole("SystemAdmin") ?? false
    };

    // Financial statement ratification: BranchApprover verifies at BranchReview; HOReviewer re-checks at HOReview
    private bool CanVerifyFinancials => application?.Status switch
    {
        AppStatus.BranchReview   => AuthService.CurrentUser?.HasRole("BranchApprover") ?? false,
        AppStatus.HOReview       => AuthService.CurrentUser?.HasRole("HOReviewer") ?? false,
        _ => AuthService.CurrentUser?.HasRole("SystemAdmin") ?? false
    };

    // Show Submit for Review button only for Draft applications owned by current user (Loan Officer)
    private bool ShowSubmitForReviewButton => application?.Status == AppStatus.Draft &&
        (AuthService.CurrentUser?.HasRole("LoanOfficer") ?? false);

    private bool CanRerunCreditChecks
    {
        get
        {
            if (application?.Status != AppStatus.CreditAnalysis) return false;
            if (!(AuthService.CurrentUser?.HasRole("CreditOfficer") ?? false)) return false;

            var reports = application!.BureauReports;

            // Existing reports in a retryable state
            if (reports.Any(r =>
                r.Status == "Failed" ||
                r.Status == "ConsentRequired" ||
                r.Status == "NotFound" ||
                (r.Status == "Completed" && r.IsScoreDerived)))
                return true;

            // Directors with a BVN that have no bureau report yet (e.g. skipped due to duplicate BVN)
            if (application.Directors.Any(d =>
                !string.IsNullOrEmpty(d.RawBVN) &&
                !reports.Any(r => r.PartyId == d.Id)))
                return true;

            // No completed non-derived business report exists (only relevant when the application has an RC number)
            if (!string.IsNullOrEmpty(application.Customer.RegistrationNumber) &&
                !reports.Any(r => r.SubjectType == "Business" && r.Status == "Completed" && !r.IsScoreDerived))
                return true;

            return false;
        }
    }

    private bool CanSetupCommitteeReview =>
        application?.Status == AppStatus.CommitteeCirculation &&
        application.Committee == null &&
        (AuthService.CurrentUser?.HasRole("CreditOfficer") ?? false);

    private bool CanManageCommitteeReview =>
        application?.Status == AppStatus.CommitteeCirculation &&
        application.Committee?.Status == "Pending" &&
        (AuthService.CurrentUser?.HasRole("CreditOfficer") ?? false);

    private bool IsAssignedCommitteeMember =>
        application?.Committee?.Members.Any(m => m.UserId == (AuthService.CurrentUser?.Id ?? Guid.Empty)) == true;

    private bool CanConfirmCommitteeDecision =>
        application?.Status == AppStatus.CommitteeCirculation &&
        (AuthService.CurrentUser?.HasRole("CreditOfficer") ?? false) &&
        (application.Committee?.Status is "VotingComplete" or "InProgress") &&
        (application.Committee.Status == "VotingComplete" ||
         (application.Committee.IsOverdue && application.Committee.HasQuorum));

    private bool ShowApproveButton => application?.Status switch
    {
        AppStatus.BranchReview               => AuthService.CurrentUser?.HasRole("BranchApprover") ?? false,
        AppStatus.CreditAnalysis             => AuthService.CurrentUser?.HasRole("CreditOfficer") ?? false,
        AppStatus.HOReview                   => AuthService.CurrentUser?.HasRole("HOReviewer") ?? false,
        AppStatus.LegalReview                => AuthService.CurrentUser?.HasRole("LegalOfficer") ?? false,
        AppStatus.LegalApproval              => AuthService.CurrentUser?.HasRole("HeadOfLegal") ?? false,
        AppStatus.FinalApproval              => AuthService.CurrentUser?.HasRole("FinalApprover") ?? false,
        AppStatus.SecurityPerfection         => AuthService.CurrentUser?.HasRole("LegalOfficer") ?? false,
        AppStatus.SecurityApproval           => AuthService.CurrentUser?.HasRole("HeadOfLegal") ?? false,
        AppStatus.DisbursementPending        => AuthService.CurrentUser?.HasRole("Operations") ?? false,
        AppStatus.DisbursementBranchApproval => AuthService.CurrentUser?.HasRole("BranchApprover") ?? false,
        _ => false
    };

    private bool ShowReturnButton => application?.Status switch
    {
        AppStatus.BranchReview               => AuthService.CurrentUser?.HasRole("BranchApprover") ?? false,
        AppStatus.CreditAnalysis             => AuthService.CurrentUser?.HasRole("CreditOfficer") ?? false,
        AppStatus.HOReview                   => AuthService.CurrentUser?.HasRole("HOReviewer") ?? false,
        AppStatus.LegalReview                => AuthService.CurrentUser?.HasRole("LegalOfficer") ?? false,
        AppStatus.LegalApproval              => AuthService.CurrentUser?.HasRole("HeadOfLegal") ?? false,
        AppStatus.SecurityApproval           => AuthService.CurrentUser?.HasRole("HeadOfLegal") ?? false,
        AppStatus.DisbursementBranchApproval => AuthService.CurrentUser?.HasRole("BranchApprover") ?? false,
        _ => false
    };

    private bool ShowRejectButton => application?.Status switch
    {
        AppStatus.BranchReview => AuthService.CurrentUser?.HasRole("BranchApprover") ?? false,
        AppStatus.HOReview => AuthService.CurrentUser?.HasRole("HOReviewer") ?? false,
        AppStatus.FinalApproval => AuthService.CurrentUser?.HasRole("FinalApprover") ?? false,
        _ => false
    };

    private void ShowActionModal(ActionType action)
    {
        currentAction = action;
        actionComments = string.Empty;
        actionError = null;
        showActionModal = true;
    }

    private async Task HandleApproveClick()
    {
        if (application == null) return;
        var stage = application.Status;

        // Only check gate for stages that have a gate
        if (stage is not (AppStatus.BranchReview or AppStatus.HOReview or AppStatus.CreditAnalysis or AppStatus.FinalApproval))
        {
            ShowActionModal(ActionType.Approve);
            return;
        }

        isCheckingGate = true;
        approvalGateResult = await AppService.CheckApprovalGateAsync(Id, stage);
        isCheckingGate = false;

        if (approvalGateResult == null || !approvalGateResult.HasIssues)
        {
            // Gate clear — proceed normally
            ShowActionModal(ActionType.Approve);
            return;
        }

        showApprovalGateModal = true;
    }

    private void CloseApprovalGateModal()
    {
        showApprovalGateModal = false;
        approvalGateResult = null;
    }

    private async Task HandleGateProceed(string? overrideNote)
    {
        showApprovalGateModal = false;

        // Save override note if provided
        if (!string.IsNullOrWhiteSpace(overrideNote) && application != null)
        {
            if (!EnsureAuthenticated(out var actorId)) return;
            var actorName = AuthService.CurrentUser?.FullName ?? "Unknown";
            await AppService.SaveApprovalOverrideAsync(Id, application.Status, actorId, actorName, overrideNote);
        }

        // Now open the standard approval modal
        ShowActionModal(ActionType.Approve);
    }

    private void CloseActionModal()
    {
        showActionModal = false;
        actionComments = string.Empty;
        actionError = null;
    }

    private string GetActionTitle() => currentAction switch
    {
        ActionType.Approve => "Approve Application",
        ActionType.Return => "Return for Correction",
        ActionType.Reject => "Reject Application",
        _ => "Action"
    };

    private string GetActionButtonClass() => currentAction switch
    {
        ActionType.Approve => "btn-success",
        ActionType.Return => "btn-warning",
        ActionType.Reject => "btn-danger",
        _ => "btn-primary"
    };

    private string GetActionButtonText() => currentAction switch
    {
        ActionType.Approve => "Confirm Approval",
        ActionType.Return => "Return Application",
        ActionType.Reject => "Confirm Rejection",
        _ => "Submit"
    };

    private bool EnsureAuthenticated(out Guid userId)
    {
        if (AuthService.CurrentUser == null)
        {
            Navigation.NavigateTo("/login", true);
            userId = Guid.Empty;
            return false;
        }
        userId = AuthService.CurrentUser.Id;
        return true;
    }

    private async Task ExecuteAction()
    {
        if (currentAction != ActionType.Approve && string.IsNullOrWhiteSpace(actionComments))
        {
            return;
        }

        isExecutingAction = true;
        
        if (!EnsureAuthenticated(out var userId)) return;
        var userRole = AuthService.CurrentUser!.Roles.FirstOrDefault() ?? "User";
        
        ApiResponse result = currentAction switch
        {
            ActionType.Approve => await AppService.ApproveApplicationAsync(Id, actionComments, userId, userRole),
            ActionType.Return => await AppService.ReturnApplicationAsync(Id, actionComments, userId, userRole),
            ActionType.Reject => await AppService.RejectApplicationAsync(Id, actionComments, userId, userRole),
            _ => ApiResponse.Fail("Unknown action")
        };

        isExecutingAction = false;

        if (result.Success)
        {
            CloseActionModal();
            await LoadApplication();
        }
        else
        {
            actionError = result.Error ?? "Action failed. Please try again.";
        }
    }

