@page "/reports/performance"
@inject ApplicationService AppService
@inject NavigationManager Navigation

<PageTitle>Performance Report - CRMS</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Performance Report</h1>
        <p class="page-subtitle">Staff and team performance metrics</p>
    </div>
    <div style="display: flex; gap: var(--space-3);">
        <select class="form-control" style="width: 150px;" @bind="selectedPeriod" @bind:after="LoadData">
            <option value="7">Last 7 days</option>
            <option value="30">Last 30 days</option>
            <option value="90">Last 90 days</option>
        </select>
        <button class="btn btn-secondary" disabled title="Export functionality coming soon">
            <span class="material-symbols-outlined" style="font-size: 18px;">download</span>
            Export
        </button>
    </div>
</div>

@if (isLoading)
{
    <div style="display: flex; justify-content: center; padding: var(--space-12);">
        <div class="spinner"></div>
    </div>
}
else
{
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon primary">
                <span class="material-symbols-outlined">schedule</span>
            </div>
            <div class="stat-content">
                <div class="stat-label">Avg. Processing Time</div>
                <div class="stat-value">@data.AvgProcessingTimeDays.ToString("0.#") days</div>
                @{
                    var timeDiff = data.AvgProcessingTimeDays - data.PrevAvgProcessingTimeDays;
                }
                <div class="stat-change @(timeDiff <= 0 ? "positive" : "negative")">
                    <span class="material-symbols-outlined" style="font-size: 16px;">@(timeDiff <= 0 ? "trending_down" : "trending_up")</span>
                    @(timeDiff <= 0 ? "" : "+")@timeDiff.ToString("0.#") days vs prev period
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon success">
                <span class="material-symbols-outlined">check_circle</span>
            </div>
            <div class="stat-content">
                <div class="stat-label">SLA Compliance</div>
                <div class="stat-value">@data.SlaComplianceRate.ToString("0.#")%</div>
                @{
                    var slaDiff = data.SlaComplianceRate - data.PrevSlaComplianceRate;
                }
                <div class="stat-change @(slaDiff >= 0 ? "positive" : "negative")">
                    <span class="material-symbols-outlined" style="font-size: 16px;">@(slaDiff >= 0 ? "trending_up" : "trending_down")</span>
                    @(slaDiff >= 0 ? "+" : "")@slaDiff.ToString("0.#")% from prev period
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon warning">
                <span class="material-symbols-outlined">assignment</span>
            </div>
            <div class="stat-content">
                <div class="stat-label">Applications Processed</div>
                <div class="stat-value">@data.ApplicationsProcessed</div>
                @{
                    var appGrowth = data.PrevApplicationsProcessed > 0
                        ? (decimal)(data.ApplicationsProcessed - data.PrevApplicationsProcessed) / data.PrevApplicationsProcessed * 100
                        : 0;
                }
                <div class="stat-change @(appGrowth >= 0 ? "positive" : "negative")">
                    <span class="material-symbols-outlined" style="font-size: 16px;">@(appGrowth >= 0 ? "trending_up" : "trending_down")</span>
                    @(appGrowth >= 0 ? "+" : "")@appGrowth.ToString("0.#")% from prev period
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon danger">
                <span class="material-symbols-outlined">warning</span>
            </div>
            <div class="stat-content">
                <div class="stat-label">SLA Breaches</div>
                <div class="stat-value">@data.SlaBreaches</div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-2 gap-6 mt-6">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Processing Time by Stage</h3>
            </div>
            <div class="card-body">
                @if (data.StagePerformance.Any())
                {
                    @foreach (var stage in data.StagePerformance)
                    {
                        <div class="stage-row">
                            <div class="stage-info">
                                <span class="stage-name">@stage.Name</span>
                                <span class="stage-target">Target: @stage.TargetHours hrs</span>
                            </div>
                            <div class="stage-bar-container">
                                @{
                                    var barWidth = stage.TargetHours > 0
                                        ? Math.Min(stage.ActualHours / (stage.TargetHours * 1.5m) * 100, 100)
                                        : 0;
                                }
                                <div class="stage-bar @(stage.ActualHours > stage.TargetHours ? "exceeded" : "")"
                                     style="width: @barWidth%"></div>
                            </div>
                            <span class="stage-actual @(stage.ActualHours > stage.TargetHours ? "text-danger" : "")">
                                @stage.ActualHours.ToString("0.#") hrs
                            </span>
                        </div>
                    }
                }
                else
                {
                    <p style="color: var(--gray-500); text-align: center; padding: var(--space-4);">No stage data available for this period</p>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Top Performers</h3>
            </div>
            <div class="card-body" style="padding: 0;">
                @if (data.TopPerformers.Any())
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Processed</th>
                                <th>Avg. Time</th>
                                <th>SLA %</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var performer in data.TopPerformers.Take(10))
                            {
                                <tr>
                                    <td>
                                        <div style="display: flex; align-items: center; gap: var(--space-2);">
                                            <div class="user-avatar" style="width: 28px; height: 28px; font-size: 10px;">@performer.Initials</div>
                                            <span>@performer.Name</span>
                                        </div>
                                    </td>
                                    <td style="font-weight: 500;">@performer.ProcessedCount</td>
                                    <td>@performer.AvgHours.ToString("0.#") hrs</td>
                                    <td>
                                        <span class="badge @(performer.SlaCompliance >= 90 ? "badge-success" : performer.SlaCompliance >= 75 ? "badge-warning" : "badge-danger")">
                                            @performer.SlaCompliance%
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p style="color: var(--gray-500); text-align: center; padding: var(--space-4);">No performer data available for this period</p>
                }
            </div>
        </div>
    </div>

    <div class="card mt-6">
        <div class="card-header">
            <h3 class="card-title">Performance by Stage</h3>
        </div>
        <div class="card-body" style="padding: 0;">
            @if (data.TeamPerformance.Any())
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Stage</th>
                            <th>Total Processed</th>
                            <th>Avg. Processing Time</th>
                            <th>SLA Compliance</th>
                            <th>Trend</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var team in data.TeamPerformance)
                        {
                            <tr>
                                <td style="font-weight: 500;">@team.Name</td>
                                <td>@team.TotalProcessed</td>
                                <td>@team.AvgHours.ToString("0.#") hrs</td>
                                <td>
                                    <div style="display: flex; align-items: center; gap: var(--space-2);">
                                        <div class="sla-mini-bar">
                                            <div class="sla-mini-fill @(team.SlaCompliance >= 90 ? "success" : team.SlaCompliance >= 75 ? "warning" : "danger")"
                                                 style="width: @team.SlaCompliance%"></div>
                                        </div>
                                        <span>@team.SlaCompliance%</span>
                                    </div>
                                </td>
                                <td>
                                    @if (team.TrendUp)
                                    {
                                        <span class="material-symbols-outlined text-success" style="font-size: 18px;">trending_up</span>
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-danger" style="font-size: 18px;">trending_down</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p style="color: var(--gray-500); text-align: center; padding: var(--space-4);">No data available for this period</p>
            }
        </div>
    </div>
}

<style>
    .stage-row {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        margin-bottom: var(--space-4);
    }

    .stage-info {
        width: 150px;
    }

    .stage-name {
        display: block;
        font-size: var(--text-sm);
        font-weight: 500;
    }

    .stage-target {
        display: block;
        font-size: var(--text-xs);
        color: var(--gray-500);
    }

    .stage-bar-container {
        flex: 1;
        height: 8px;
        background: var(--gray-100);
        border-radius: var(--radius-full);
        overflow: hidden;
    }

    .stage-bar {
        height: 100%;
        background: var(--success-500);
        border-radius: var(--radius-full);
    }

    .stage-bar.exceeded {
        background: var(--danger-500);
    }

    .stage-actual {
        width: 60px;
        text-align: right;
        font-size: var(--text-sm);
        font-weight: 500;
    }

    .sla-mini-bar {
        width: 60px;
        height: 6px;
        background: var(--gray-200);
        border-radius: var(--radius-full);
        overflow: hidden;
    }

    .sla-mini-fill {
        height: 100%;
        border-radius: var(--radius-full);
    }

    .sla-mini-fill.success { background: var(--success-500); }
    .sla-mini-fill.warning { background: var(--warning-500); }
    .sla-mini-fill.danger { background: var(--danger-500); }
</style>

@code {
    private int selectedPeriod = 30;
    private bool isLoading = true;
    private PerformanceReportData data = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();
        data = await AppService.GetPerformanceReportDataAsync(selectedPeriod);
        isLoading = false;
    }
}
