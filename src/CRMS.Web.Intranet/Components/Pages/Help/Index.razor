@page "/help"
@page "/help/{Section}"
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Help &amp; User Guide - CRMS</PageTitle>

<div class="help-container">
    @* Hero Section for Overview *@
    @if (string.IsNullOrEmpty(Section) || CurrentSection == "overview")
    {
        <div class="help-hero">
            <div class="hero-content">
                <div class="hero-icon">
                    <span class="material-symbols-outlined">school</span>
                </div>
                <h1>Welcome to CRMS Help Center</h1>
                <p>Your complete guide to the Credit Risk Management System</p>
                <div class="hero-role">
                    <span class="material-symbols-outlined">person</span>
                    You are logged in as <strong>@CurrentRoleName</strong>
                </div>
            </div>
        </div>
    }

    <div class="help-layout">
        @* Left Sidebar Navigation *@
        <aside class="help-sidebar">
            <div class="sidebar-search">
                <span class="material-symbols-outlined">search</span>
                <input type="text" placeholder="Search help topics..." @bind="searchQuery" @bind:event="oninput" />
            </div>
            
            <nav class="sidebar-nav">
                @if (!string.IsNullOrEmpty(searchQuery))
                {
                    <div class="nav-category">
                        <div class="nav-category-header">
                            <span class="material-symbols-outlined">search</span>
                            Search Results
                        </div>
                        @if (!SearchResults.Any())
                        {
                            <div style="padding: var(--space-2) var(--space-4); font-size: var(--text-sm); color: var(--gray-500);">No results found</div>
                        }
                        @foreach (var item in SearchResults)
                        {
                            <a class="nav-item @IsActive(item.Key)" href="/help/@item.Key">
                                <span class="nav-dot"></span>@item.Label
                            </a>
                        }
                    </div>
                }
                else
                {
                @* Getting Started *@
                <div class="nav-category">
                    <div class="nav-category-header">
                        <span class="material-symbols-outlined">rocket_launch</span>
                        Getting Started
                    </div>
                    <a class="nav-item @IsActive("overview")" href="/help/overview">
                        <span class="nav-dot"></span>System Overview
                    </a>
                    <a class="nav-item @IsActive("your-role")" href="/help/your-role">
                        <span class="nav-dot"></span>Your Role Guide
                        <span class="nav-badge role">@GetRoleAbbrev()</span>
                    </a>
                </div>

                @* Menu Items Guide *@
                <div class="nav-category">
                    <div class="nav-category-header">
                        <span class="material-symbols-outlined">menu</span>
                        Menu Items Explained
                    </div>
                    <a class="nav-item @IsActive("menu-dashboard")" href="/help/menu-dashboard">
                        <span class="nav-dot"></span>Dashboard
                    </a>
                    <a class="nav-item @IsActive("menu-applications")" href="/help/menu-applications">
                        <span class="nav-dot"></span>Applications
                    </a>
                    <a class="nav-item @IsActive("menu-new-application")" href="/help/menu-new-application">
                        <span class="nav-dot"></span>New Application
                    </a>
                    <a class="nav-item @IsActive("menu-my-queue")" href="/help/menu-my-queue">
                        <span class="nav-dot"></span>My Queue
                    </a>
                    <a class="nav-item @IsActive("menu-all-queues")" href="/help/menu-all-queues">
                        <span class="nav-dot"></span>All Queues
                    </a>
                    <a class="nav-item @IsActive("menu-overdue")" href="/help/menu-overdue">
                        <span class="nav-dot"></span>Overdue
                    </a>
                    <a class="nav-item @IsActive("menu-pending-votes")" href="/help/menu-pending-votes">
                        <span class="nav-dot"></span>My Pending Votes
                    </a>
                    <a class="nav-item @IsActive("menu-committee-reviews")" href="/help/menu-committee-reviews">
                        <span class="nav-dot"></span>Committee Reviews
                    </a>
                    <a class="nav-item @IsActive("menu-reports")" href="/help/menu-reports">
                        <span class="nav-dot"></span>Reports
                    </a>
                    <a class="nav-item @IsActive("menu-audit-trail")" href="/help/menu-audit-trail">
                        <span class="nav-dot"></span>Audit Trail
                    </a>
                </div>

                @* Administration Menu *@
                <div class="nav-category">
                    <div class="nav-category-header">
                        <span class="material-symbols-outlined">settings</span>
                        Administration
                    </div>
                    <a class="nav-item @IsActive("admin-users")" href="/help/admin-users">
                        <span class="nav-dot"></span>Users Management
                    </a>
                    <a class="nav-item @IsActive("admin-products")" href="/help/admin-products">
                        <span class="nav-dot"></span>Products
                    </a>
                    <a class="nav-item @IsActive("admin-locations")" href="/help/admin-locations">
                        <span class="nav-dot"></span>Locations
                    </a>
                    <a class="nav-item @IsActive("admin-committees")" href="/help/admin-committees">
                        <span class="nav-dot"></span>Committees
                    </a>
                    <a class="nav-item @IsActive("admin-scoring")" href="/help/admin-scoring">
                        <span class="nav-dot"></span>Scoring Config
                    </a>
                    <a class="nav-item @IsActive("admin-templates")" href="/help/admin-templates">
                        <span class="nav-dot"></span>Templates
                    </a>
                </div>

                @* Loan Process *@
                <div class="nav-category">
                    <div class="nav-category-header">
                        <span class="material-symbols-outlined">account_balance</span>
                        Loan Process
                    </div>
                    <a class="nav-item @IsActive("workflow")" href="/help/workflow">
                        <span class="nav-dot"></span>Complete Workflow
                    </a>
                    <a class="nav-item @IsActive("creating-application")" href="/help/creating-application">
                        <span class="nav-dot"></span>Creating Applications
                    </a>
                    <a class="nav-item @IsActive("application-statuses")" href="/help/application-statuses">
                        <span class="nav-dot"></span>Application Statuses
                    </a>
                    <a class="nav-item @IsActive("workflow-actions")" href="/help/workflow-actions">
                        <span class="nav-dot"></span>Workflow Actions
                    </a>
                    <a class="nav-item @IsActive("offer-letter")" href="/help/offer-letter">
                        <span class="nav-dot"></span>Offer Letter
                        <span class="nav-badge" style="background: var(--success-50); color: var(--success-700);">New</span>
                    </a>
                </div>

                @* Application Tabs *@
                <div class="nav-category">
                    <div class="nav-category-header">
                        <span class="material-symbols-outlined">tab</span>
                        Application Tabs
                    </div>
                    <a class="nav-item @IsActive("tab-overview")" href="/help/tab-overview">
                        <span class="nav-dot"></span>Overview Tab
                    </a>
                    <a class="nav-item @IsActive("tab-documents")" href="/help/tab-documents">
                        <span class="nav-dot"></span>Documents Tab
                    </a>
                    <a class="nav-item @IsActive("tab-collateral")" href="/help/tab-collateral">
                        <span class="nav-dot"></span>Collateral Tab
                    </a>
                    <a class="nav-item @IsActive("tab-guarantors")" href="/help/tab-guarantors">
                        <span class="nav-dot"></span>Guarantors Tab
                    </a>
                    <a class="nav-item @IsActive("tab-financials")" href="/help/tab-financials">
                        <span class="nav-dot"></span>Financials Tab
                    </a>
                    <a class="nav-item @IsActive("tab-statements")" href="/help/tab-statements">
                        <span class="nav-dot"></span>Bank Statements Tab
                    </a>
                    <a class="nav-item @IsActive("tab-bureau")" href="/help/tab-bureau">
                        <span class="nav-dot"></span>Bureau Tab
                    </a>
                    <a class="nav-item @IsActive("tab-advisory")" href="/help/tab-advisory">
                        <span class="nav-dot"></span>Advisory Tab
                    </a>
                    <a class="nav-item @IsActive("tab-committee")" href="/help/tab-committee">
                        <span class="nav-dot"></span>Committee Tab
                    </a>
                    <a class="nav-item @IsActive("tab-workflow")" href="/help/tab-workflow">
                        <span class="nav-dot"></span>Workflow Tab
                    </a>
                </div>

                @* Credit Assessment *@
                <div class="nav-category">
                    <div class="nav-category-header">
                        <span class="material-symbols-outlined">psychology</span>
                        Credit Assessment
                    </div>
                    <a class="nav-item @IsActive("scoring-algorithm")" href="/help/scoring-algorithm">
                        <span class="nav-dot"></span>Scoring Algorithm
                    </a>
                    <a class="nav-item @IsActive("ai-advisory")" href="/help/ai-advisory">
                        <span class="nav-dot"></span>AI Advisory System
                    </a>
                    <a class="nav-item @IsActive("credit-bureau")" href="/help/credit-bureau">
                        <span class="nav-dot"></span>Credit Bureau Checks
                    </a>
                    <a class="nav-item @IsActive("risk-categories")" href="/help/risk-categories">
                        <span class="nav-dot"></span>Risk Categories
                    </a>
                </div>

                @* Reference *@
                <div class="nav-category">
                    <div class="nav-category-header">
                        <span class="material-symbols-outlined">menu_book</span>
                        Reference
                    </div>
                    <a class="nav-item @IsActive("glossary")" href="/help/glossary">
                        <span class="nav-dot"></span>Glossary
                    </a>
                    <a class="nav-item @IsActive("faq")" href="/help/faq">
                        <span class="nav-dot"></span>FAQ
                    </a>
                    <a class="nav-item @IsActive("shortcuts")" href="/help/shortcuts">
                        <span class="nav-dot"></span>Keyboard Shortcuts
                    </a>
                </div>
                }
            </nav>
        </aside>

        @* Main Content Area *@
        <main class="help-content">
            @switch (CurrentSection)
            {
                case "overview":
                    @RenderOverview()
                    break;
                case "your-role":
                    @RenderYourRole()
                    break;
                case "menu-dashboard":
                    @RenderMenuDashboard()
                    break;
                case "menu-applications":
                    @RenderMenuApplications()
                    break;
                case "menu-new-application":
                    @RenderMenuNewApplication()
                    break;
                case "menu-my-queue":
                    @RenderMenuMyQueue()
                    break;
                case "menu-all-queues":
                    @RenderMenuAllQueues()
                    break;
                case "menu-overdue":
                    @RenderMenuOverdue()
                    break;
                case "menu-pending-votes":
                    @RenderMenuPendingVotes()
                    break;
                case "menu-committee-reviews":
                    @RenderMenuCommitteeReviews()
                    break;
                case "menu-reports":
                    @RenderMenuReports()
                    break;
                case "menu-audit-trail":
                    @RenderMenuAuditTrail()
                    break;
                case "admin-users":
                    @RenderAdminUsers()
                    break;
                case "admin-products":
                    @RenderAdminProducts()
                    break;
                case "admin-locations":
                    @RenderAdminLocations()
                    break;
                case "admin-committees":
                    @RenderAdminCommittees()
                    break;
                case "admin-scoring":
                    @RenderAdminScoring()
                    break;
                case "admin-templates":
                    @RenderAdminTemplates()
                    break;
                case "workflow":
                    @RenderWorkflow()
                    break;
                case "creating-application":
                    @RenderCreatingApplication()
                    break;
                case "application-statuses":
                    @RenderApplicationStatuses()
                    break;
                case "workflow-actions":
                    @RenderWorkflowActions()
                    break;
                case "offer-letter":
                    @RenderOfferLetter()
                    break;
                case "tab-overview":
                    @RenderTabOverview()
                    break;
                case "tab-documents":
                    @RenderTabDocuments()
                    break;
                case "tab-collateral":
                    @RenderTabCollateral()
                    break;
                case "tab-guarantors":
                    @RenderTabGuarantors()
                    break;
                case "tab-financials":
                    @RenderTabFinancials()
                    break;
                case "tab-statements":
                    @RenderTabStatements()
                    break;
                case "tab-bureau":
                    @RenderTabBureau()
                    break;
                case "tab-advisory":
                    @RenderTabAdvisory()
                    break;
                case "tab-committee":
                    @RenderTabCommittee()
                    break;
                case "tab-workflow":
                    @RenderTabWorkflow()
                    break;
                case "scoring-algorithm":
                    @RenderScoringAlgorithm()
                    break;
                case "ai-advisory":
                    @RenderAIAdvisory()
                    break;
                case "credit-bureau":
                    @RenderCreditBureau()
                    break;
                case "risk-categories":
                    @RenderRiskCategories()
                    break;
                case "glossary":
                    @RenderGlossary()
                    break;
                case "faq":
                    @RenderFAQ()
                    break;
                case "shortcuts":
                    @RenderShortcuts()
                    break;
                default:
                    @RenderOverview()
                    break;
            }
        </main>
    </div>
</div>

@code {
    [Parameter] public string? Section { get; set; }
    
    private string searchQuery = "";
    private string CurrentSection => string.IsNullOrEmpty(Section) ? "overview" : Section.ToLower();
    private UserInfo? User => AuthService.CurrentUser;
    
    private string CurrentRoleName => User?.PrimaryRole switch
    {
        "LoanOfficer" => "Loan Officer",
        "BranchApprover" => "Branch Approver",
        "CreditOfficer" => "Credit Officer",
        "HOReviewer" => "HO Reviewer",
        "CommitteeMember" => "Committee Member",
        "FinalApprover" => "Final Approver",
        "Operations" => "Operations",
        "RiskManager" => "Risk Manager",
        "Auditor" => "Auditor",
        "SystemAdmin" => "System Administrator",
        _ => "Staff Member"
    };

    private string GetRoleAbbrev() => User?.PrimaryRole switch
    {
        "LoanOfficer" => "LO",
        "BranchApprover" => "BA",
        "CreditOfficer" => "CO",
        "HOReviewer" => "HO",
        "CommitteeMember" => "CM",
        "FinalApprover" => "FA",
        "Operations" => "OP",
        "RiskManager" => "RM",
        "Auditor" => "AU",
        "SystemAdmin" => "SA",
        _ => "?"
    };

    private string IsActive(string section) => CurrentSection == section ? "active" : "";

    private static readonly List<(string Key, string Label)> HelpNavItems =
    [
        ("overview", "System Overview"),
        ("your-role", "Your Role Guide"),
        ("menu-dashboard", "Dashboard"),
        ("menu-applications", "Applications"),
        ("menu-new-application", "New Application"),
        ("menu-my-queue", "My Queue"),
        ("menu-all-queues", "All Queues"),
        ("menu-overdue", "Overdue"),
        ("menu-pending-votes", "My Pending Votes"),
        ("menu-committee-reviews", "Committee Reviews"),
        ("menu-reports", "Reports"),
        ("menu-audit-trail", "Audit Trail"),
        ("admin-users", "Users Management"),
        ("admin-products", "Products"),
        ("admin-locations", "Locations"),
        ("admin-committees", "Committees"),
        ("admin-scoring", "Scoring Config"),
        ("admin-templates", "Templates"),
        ("workflow", "Complete Workflow"),
        ("creating-application", "Creating Applications"),
        ("application-statuses", "Application Statuses"),
        ("workflow-actions", "Workflow Actions"),
        ("offer-letter", "Offer Letter"),
        ("tab-overview", "Overview Tab"),
        ("tab-documents", "Documents Tab"),
        ("tab-collateral", "Collateral Tab"),
        ("tab-guarantors", "Guarantors Tab"),
        ("tab-financials", "Financials Tab"),
        ("tab-statements", "Bank Statements Tab"),
        ("tab-bureau", "Bureau Tab"),
        ("tab-advisory", "Advisory Tab"),
        ("tab-committee", "Committee Tab"),
        ("tab-workflow", "Workflow Tab"),
        ("scoring-algorithm", "Scoring Algorithm"),
        ("ai-advisory", "AI Advisory System"),
        ("credit-bureau", "Credit Bureau Checks"),
        ("risk-categories", "Risk Categories"),
        ("glossary", "Glossary"),
        ("faq", "FAQ"),
        ("shortcuts", "Keyboard Shortcuts"),
    ];

    private IEnumerable<(string Key, string Label)> SearchResults =>
        string.IsNullOrWhiteSpace(searchQuery) ? [] :
        HelpNavItems.Where(item => item.Label.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

    // ==================== OVERVIEW ====================
    private RenderFragment RenderOverview() => __builder =>
    {
        <div class="content-card">
            <h2>What is CRMS?</h2>
            <p class="intro-text">CRMS (Credit Risk Management System) is a comprehensive corporate loan origination platform that handles the complete lifecycle of loan applications - from customer inquiry through final disbursement.</p>
            
            <div class="feature-grid">
                <div class="feature-card">
                    <div class="feature-icon blue">
                        <span class="material-symbols-outlined">cloud_sync</span>
                    </div>
                    <h4>Automated Data Collection</h4>
                    <p>Pulls customer data from Core Banking and directors from CAC via SmartComply</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon green">
                        <span class="material-symbols-outlined">verified_user</span>
                    </div>
                    <h4>Credit Bureau Integration</h4>
                    <p>Automatic credit checks for all directors, signatories, and guarantors</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon purple">
                        <span class="material-symbols-outlined">psychology</span>
                    </div>
                    <h4>AI-Powered Risk Assessment</h4>
                    <p>Rule-based scoring algorithm with configurable thresholds</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon orange">
                        <span class="material-symbols-outlined">groups</span>
                    </div>
                    <h4>Committee Workflow</h4>
                    <p>Amount-based routing to appropriate approval committees</p>
                </div>
            </div>
        </div>

        <div class="content-card">
            <h2>How Loan Processing Works</h2>
            <p>Every corporate loan application flows through these stages:</p>
            
            <div class="visual-workflow">
                <div class="workflow-step">
                    <div class="step-circle draft">
                        <span class="material-symbols-outlined">edit_note</span>
                    </div>
                    <div class="step-info">
                        <h4>1. Draft</h4>
                        <p>Loan Officer creates application, uploads documents, adds collateral and guarantors</p>
                        <span class="step-actor">Loan Officer</span>
                    </div>
                </div>
                
                <div class="workflow-connector">
                    <div class="connector-line"></div>
                    <span class="connector-action">Submit</span>
                </div>
                
                <div class="workflow-step">
                    <div class="step-circle review">
                        <span class="material-symbols-outlined">fact_check</span>
                    </div>
                    <div class="step-info">
                        <h4>2. Branch Review</h4>
                        <p>Branch Approver verifies completeness and validates documents</p>
                        <span class="step-actor">Branch Approver</span>
                    </div>
                </div>
                
                <div class="workflow-connector">
                    <div class="connector-line"></div>
                    <span class="connector-action">Approve</span>
                </div>
                
                <div class="workflow-step">
                    <div class="step-circle analysis">
                        <span class="material-symbols-outlined">analytics</span>
                    </div>
                    <div class="step-info">
                        <h4>3. Credit Analysis</h4>
                        <p>Credit Officer analyzes risk, valuates collateral, generates AI advisory</p>
                        <span class="step-actor">Credit Officer</span>
                    </div>
                </div>
                
                <div class="workflow-connector">
                    <div class="connector-line"></div>
                    <span class="connector-action">Setup Committee</span>
                </div>
                
                <div class="workflow-step">
                    <div class="step-circle committee">
                        <span class="material-symbols-outlined">how_to_vote</span>
                    </div>
                    <div class="step-info">
                        <h4>4. Committee Review</h4>
                        <p>Committee members review loan pack and cast votes</p>
                        <span class="step-actor">Committee Members</span>
                    </div>
                </div>
                
                <div class="workflow-connector">
                    <div class="connector-line"></div>
                    <span class="connector-action">Decision</span>
                </div>
                
                <div class="workflow-step">
                    <div class="step-circle approval">
                        <span class="material-symbols-outlined">verified</span>
                    </div>
                    <div class="step-info">
                        <h4>5. Final Approval</h4>
                        <p>Final Approver confirms terms and authorizes disbursement</p>
                        <span class="step-actor">Final Approver</span>
                    </div>
                </div>
                
                <div class="workflow-connector">
                    <div class="connector-line"></div>
                    <span class="connector-action">Approve</span>
                </div>
                
                <div class="workflow-step">
                    <div class="step-circle disbursed">
                        <span class="material-symbols-outlined">payments</span>
                    </div>
                    <div class="step-info">
                        <h4>6. Disbursement</h4>
                        <p>Operations books loan in Core Banking and processes disbursement</p>
                        <span class="step-actor">Operations</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="content-card">
            <h2>Quick Navigation</h2>
            <p>Jump to the section most relevant to you:</p>
            
            <div class="quick-nav-grid">
                <a href="/help/your-role" class="quick-nav-card">
                    <span class="material-symbols-outlined">person</span>
                    <span class="quick-nav-title">Your Role Guide</span>
                    <span class="quick-nav-desc">Learn what you can do</span>
                </a>
                <a href="/help/menu-my-queue" class="quick-nav-card">
                    <span class="material-symbols-outlined">inbox</span>
                    <span class="quick-nav-title">My Queue</span>
                    <span class="quick-nav-desc">Your pending work</span>
                </a>
                <a href="/help/creating-application" class="quick-nav-card">
                    <span class="material-symbols-outlined">add_circle</span>
                    <span class="quick-nav-title">Create Application</span>
                    <span class="quick-nav-desc">Step-by-step guide</span>
                </a>
                <a href="/help/scoring-algorithm" class="quick-nav-card">
                    <span class="material-symbols-outlined">psychology</span>
                    <span class="quick-nav-title">Scoring Algorithm</span>
                    <span class="quick-nav-desc">How risk is calculated</span>
                </a>
                <a href="/help/glossary" class="quick-nav-card">
                    <span class="material-symbols-outlined">menu_book</span>
                    <span class="quick-nav-title">Glossary</span>
                    <span class="quick-nav-desc">Terms explained</span>
                </a>
                <a href="/help/faq" class="quick-nav-card">
                    <span class="material-symbols-outlined">help</span>
                    <span class="quick-nav-title">FAQ</span>
                    <span class="quick-nav-desc">Common questions</span>
                </a>
            </div>
        </div>
    };

    // ==================== YOUR ROLE ====================
    private RenderFragment RenderYourRole() => __builder =>
    {
        <div class="content-header">
            <span class="header-icon"><span class="material-symbols-outlined">badge</span></span>
            <div>
                <h1>Your Role: @CurrentRoleName</h1>
                <p>What you can see and do in CRMS</p>
            </div>
        </div>

        @if (User?.HasRole("LoanOfficer") == true)
        {
            @RenderLoanOfficerRole()
        }
        else if (User?.HasRole("BranchApprover") == true)
        {
            @RenderBranchApproverRole()
        }
        else if (User?.HasRole("CreditOfficer") == true)
        {
            @RenderCreditOfficerRole()
        }
        else if (User?.HasRole("CommitteeMember") == true)
        {
            @RenderCommitteeMemberRole()
        }
        else if (User?.HasRole("FinalApprover") == true)
        {
            @RenderFinalApproverRole()
        }
        else if (User?.HasRole("Operations") == true)
        {
            @RenderOperationsRole()
        }
        else if (User?.HasRole("RiskManager") == true)
        {
            @RenderRiskManagerRole()
        }
        else if (User?.HasRole("SystemAdmin") == true)
        {
            @RenderSystemAdminRole()
        }
        else if (User?.HasRole("Auditor") == true)
        {
            @RenderAuditorRole()
        }
        else
        {
            <div class="content-card">
                <p>Your role-specific guide will appear here once your role is properly assigned.</p>
            </div>
        }
    };

    private RenderFragment RenderLoanOfficerRole() => __builder =>
    {
        <div class="role-header-card loan-officer">
            <div class="role-icon-large">
                <span class="material-symbols-outlined">edit_document</span>
            </div>
            <div class="role-header-info">
                <h3>Primary Mission</h3>
                <p>Create loan applications and ensure all required information is complete before submission</p>
                <div class="role-tags">
                    <span class="tag">Create Applications</span>
                    <span class="tag">Upload Documents</span>
                    <span class="tag">Add Collateral</span>
                    <span class="tag">Add Guarantors</span>
                    <span class="tag">Enter Financials</span>
                </div>
            </div>
