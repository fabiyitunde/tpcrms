    private RenderFragment RenderGlossary() => __builder =>
    {
        <div class="content-header">
            <span class="header-icon"><span class="material-symbols-outlined">menu_book</span></span>
            <div>
                <h1>Glossary</h1>
                <p>Definitions of key terms</p>
            </div>
        </div>

        <div class="content-card">
            <div class="glossary-grid">
                <div class="glossary-item">
                    <dt>BVN</dt>
                    <dd>Bank Verification Number - 11-digit unique biometric identifier for Nigerian bank customers</dd>
                </div>
                <div class="glossary-item">
                    <dt>CAC</dt>
                    <dd>Corporate Affairs Commission - Nigerian government agency for company registration</dd>
                </div>
                <div class="glossary-item">
                    <dt>DSCR</dt>
                    <dd>Debt Service Coverage Ratio - EBITDA ÷ annual debt service. Measures ability to repay. Minimum 1.25 typically required.</dd>
                </div>
                <div class="glossary-item">
                    <dt>EBITDA</dt>
                    <dd>Earnings Before Interest, Taxes, Depreciation, and Amortization - measure of operating profitability</dd>
                </div>
                <div class="glossary-item">
                    <dt>FSV</dt>
                    <dd>Forced Sale Value - price collateral could be quickly sold at in distress. Typically 60-80% of market value.</dd>
                </div>
                <div class="glossary-item">
                    <dt>Haircut</dt>
                    <dd>Percentage reduction to collateral value to account for risk. 30% haircut = only 70% of value counted.</dd>
                </div>
                <div class="glossary-item">
                    <dt>LTV</dt>
                    <dd>Loan-to-Value Ratio - loan amount ÷ collateral value. Lower = better coverage.</dd>
                </div>
                <div class="glossary-item">
                    <dt>NUBAN</dt>
                    <dd>Nigeria Uniform Bank Account Number - 10-digit standardized account number</dd>
                </div>
                <div class="glossary-item">
                    <dt>Quorum</dt>
                    <dd>Minimum number of committee members who must vote for a valid decision</dd>
                </div>
                <div class="glossary-item">
                    <dt>RC Number</dt>
                    <dd>Registration Certificate Number - unique identifier from CAC for incorporated companies</dd>
                </div>
                <div class="glossary-item">
                    <dt>SLA</dt>
                    <dd>Service Level Agreement - maximum time allowed for a workflow stage before it's overdue</dd>
                </div>
                <div class="glossary-item">
                    <dt>Tenor</dt>
                    <dd>Loan duration in months. 36-month tenor = 3 year loan.</dd>
                </div>
            </div>
        </div>
    };

